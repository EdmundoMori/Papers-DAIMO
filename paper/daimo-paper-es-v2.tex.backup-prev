\label{tab:actors}
\centering
\small
\begin{tabularx}{\textwidth}{@{}L{3.5cm}L{2cm}XL{3cm}@{}}
\toprule
\textbf{Actor} & \textbf{Categoría} & \textbf{Necesidad} & \textbf{CQs} \\
\midrule
