    <!-- http://data.europa.eu/it6/ComputerInfrastructure -->


    <owl:Class rdf:about="http://data.europa.eu/it6/ComputerInfrastructure"/>
    


    <!-- http://data.europa.eu/it6/Evaluation -->


    <owl:Class rdf:about="http://data.europa.eu/it6/Evaluation"/>
    


    <!-- http://data.europa.eu/it6/Flow -->


    <owl:Class rdf:about="http://data.europa.eu/it6/Flow"/>
    


    <!-- http://data.europa.eu/it6/MachineLearningModel -->


    <owl:Class rdf:about="http://data.europa.eu/it6/MachineLearningModel"/>
    


    <!-- http://data.europa.eu/it6/Run -->


    <owl:Class rdf:about="http://data.europa.eu/it6/Run"/>
    


    <!-- http://data.europa.eu/it6/Task -->


    <owl:Class rdf:about="http://data.europa.eu/it6/Task"/>
    


    <!-- http://spdx.org/rdf/terms#Checksum -->


    <owl:Class rdf:about="http://spdx.org/rdf/terms#Checksum"/>
    


    <!-- http://www.w3.org/ns/dcat#CatalogRecord -->


    <owl:Class rdf:about="http://www.w3.org/ns/dcat#CatalogRecord"/>
    


    <!-- http://www.w3.org/ns/dcat#DataService -->


    <owl:Class rdf:about="http://www.w3.org/ns/dcat#DataService"/>
    


    <!-- http://www.w3.org/ns/dcat#Dataset -->


    <owl:Class rdf:about="http://www.w3.org/ns/dcat#Dataset"/>
    


    <!-- http://www.w3.org/ns/dcat#Resource -->


    <owl:Class rdf:about="http://www.w3.org/ns/dcat#Resource"/>
    


    <!-- http://www.w3.org/ns/odrl/2/Agreement -->


    <owl:Class rdf:about="http://www.w3.org/ns/odrl/2/Agreement"/>
    


    <!-- http://www.w3.org/ns/odrl/2/Offer -->


    <owl:Class rdf:about="http://www.w3.org/ns/odrl/2/Offer"/>
    


    <!-- http://www.w3.org/ns/prov#Activity -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Activity"/>
    


    <!-- http://www.w3.org/ns/prov#Bundle -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Bundle"/>
    


    <!-- http://www.w3.org/ns/prov#Entity -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Entity"/>
    


    <!-- http://xmlns.com/foaf/0.1/Agent -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Agent"/>
    


    <!-- http://xmlns.com/foaf/0.1/Person -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person"/>
    


    <!-- https://w3id.org/edc/v0.0.1/ns/ParticipantContext -->


    <owl:Class rdf:about="https://w3id.org/edc/v0.0.1/ns/ParticipantContext"/>
    


    <!-- https://w3id.org/pionera/daimo#AIAssetOffering -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#AIAssetOffering">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dcat#CatalogRecord"/>
        <rdfs:comment xml:lang="en">A catalog-record entry that registers an AI model in a dataspace catalog, bundling the model reference, the providing agent, and an ODRL offer policy. Specialises dcat:CatalogRecord; carries an odrl:Offer via daimo:hasOfferPolicy. In DSP terms this is the catalog-time artefact that becomes a dspace:ContractOffer during negotiation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">AI asset offering</rdfs:label>
        <skos:definition xml:lang="en">A catalog-record entry registering an AI model in a dataspace catalog as a governed offer, bundling the model, the issuing agent, and an ODRL offer policy.</skos:definition>
        <skos:example xml:lang="en">A research organisation publishing one of its machine-learning models into a dataspace catalog declares an AIAssetOffering that references the model (via offersModel), the organisation itself (via offeredBy), and an ODRL offer policy (via hasOfferPolicy) permitting use and distribution under a specific licence.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#AuditEvidence -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#AuditEvidence">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A compliance-oriented evidence record attached to a governed event, carrying integrity hash, signer, and timestamp.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">audit evidence</rdfs:label>
        <skos:definition xml:lang="en">A compliance-oriented evidence record attached to a governed activity, carrying a structured SPDX checksum (algorithm + digest), a signer, and a timestamp.</skos:definition>
        <skos:example xml:lang="en">For each run of a deployed model, the PlatformOperator produces an AuditEvidence record that references the run (daimo:evidenceOf), carries a structured spdx:Checksum (algorithm + digest) over the run&apos;s outputs (daimo:integrityHash), identifies the signer (daimo:signedBy), and timestamps the sealing (daimo:recordedAt).</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#CrossParticipantProvenanceRecord -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#CrossParticipantProvenanceRecord">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Bundle"/>
        <rdfs:comment xml:lang="en">A reusable semantic bundle that aggregates prov:Activity and prov:Entity across participant contexts to tell one audit-ready story.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">cross-participant provenance record</rdfs:label>
        <skos:definition xml:lang="en">A PROV bundle that aggregates activities and entities spanning at least two EDC participant contexts, forming an audit-ready cross-participant provenance narrative.</skos:definition>
        <skos:example xml:lang="en">When a derived artefact is produced by a consumer invoking a provider&apos;s model hosted by a third-party operator, a CrossParticipantProvenanceRecord aggregates the relevant activities across the provider, consumer, and operator participant contexts into one bundle for audit.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#DerivedArtifact -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#DerivedArtifact">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/dcat#Resource"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A governed, catalog-describable output produced by an it6:Run in a dataspace context, bearing its own provenance and policy.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">derived artifact</rdfs:label>
        <skos:definition xml:lang="en">A governed, catalog-describable output produced by a run in a dataspace context, carrying its own provenance pointer and authorisation pointer.</skos:definition>
        <skos:example xml:lang="en">When a consumer invokes a deployed model, the run&apos;s output (a prediction dataset, a classification result, a generated artefact) is typed as a DerivedArtifact that points back to the producing run (daimo:derivedFromRun) and to the authorisation under which it was produced (daimo:underAuthorization).</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#Evaluator -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#Evaluator">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pionera/daimo#ParticipantRole"/>
        <rdfs:comment xml:lang="en">Role of an agent that evaluates or compares AI models under a shared evaluation context.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">evaluator</rdfs:label>
        <skos:definition xml:lang="en">Role of an agent that evaluates or compares AI models under a shared evaluation context.</skos:definition>
        <skos:example xml:lang="en">Any agent that produces it6:Evaluation instances linked to a shared SharedEvaluationContext (via daimo:usesEvaluationContext) holds an Evaluator role — for example, a benchmarking team comparing candidate models on the same dataset version and seed.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#ExecutionAuthorization -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#ExecutionAuthorization">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/odrl/2/Agreement"/>
        <rdfs:comment xml:lang="en">An ODRL agreement (produced by a DSP contract negotiation) that binds at least one odrl:permission to concrete it6:Run invocations it authorises. Specialises odrl:Agreement; MUST carry at least one odrl:permission per the ODRL policy model.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">execution authorization</rdfs:label>
        <skos:definition xml:lang="en">An ODRL agreement, produced by a Dataspace-Protocol contract negotiation, that binds specific ODRL permissions to concrete MLDCAT-AP run invocations it authorises, with an expiry timestamp and a grantee agent.</skos:definition>
        <skos:example xml:lang="en">After a successful DSP contract negotiation, the resulting agreement is represented as an ExecutionAuthorization granting odrl:use to the consumer (daimo:grantedTo), covering one or more runs via daimo:authorizesRun, expiring at a specified daimo:expiresAt timestamp.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#GovernanceActor -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#GovernanceActor">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pionera/daimo#ParticipantRole"/>
        <rdfs:comment xml:lang="en">Role of an agent that audits execution evidence, enforces compliance obligations, and validates governance across the dataspace.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">governance actor</rdfs:label>
        <skos:definition xml:lang="en">Role of an agent that audits execution evidence, enforces compliance obligations, and validates governance across the dataspace.</skos:definition>
        <skos:example xml:lang="en">An external compliance body that reads CrossParticipantProvenanceRecord bundles and AuditEvidence records to verify lawful execution holds a GovernanceActor role — for example, a regulator or a conformance-labelling body.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#IOContract -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#IOContract">
        <rdfs:comment xml:lang="en">The minimum machine-actionable invocation contract for a deployment: input format, output format, authentication method, and optional input/output schemas.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">I/O contract</rdfs:label>
        <skos:definition xml:lang="en">The minimum machine-actionable invocation contract for a deployment endpoint: input media type, output media type, authentication method, and optional input/output schemas.</skos:definition>
        <skos:example xml:lang="en">A REST inference endpoint might declare an IOContract with inputFormat &quot;application/json&quot;, outputFormat &quot;application/geo+json&quot;, and authMethod &quot;oauth2-bearer&quot;; a parallel gRPC endpoint on the same deployment can declare a second IOContract with inputFormat &quot;application/x-protobuf&quot; and authMethod &quot;mtls&quot;.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#ModelConsumer -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#ModelConsumer">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pionera/daimo#ParticipantRole"/>
        <rdfs:comment xml:lang="en">Role of an agent that discovers, negotiates, and invokes AI models offered by a Model Provider.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">model consumer</rdfs:label>
        <skos:definition xml:lang="en">Role of an agent that discovers, negotiates access to, and invokes AI models offered by a Model Provider.</skos:definition>
        <skos:example xml:lang="en">Any agent that receives an ExecutionAuthorization (via daimo:grantedTo) and uses it to invoke runs of a deployed model holds a ModelConsumer role within the corresponding participant context.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#ModelDeployment -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#ModelDeployment">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A running or hosted instance of an MLDCAT-AP MachineLearningModel exposed through a dcat:DataService under an operational environment.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">model deployment</rdfs:label>
        <skos:definition xml:lang="en">A running or hosted instance of a machine-learning model exposed through one or more DCAT data services over a named compute infrastructure, under a per-service I/O contract.</skos:definition>
        <skos:example xml:lang="en">A PlatformOperator that stands up a live inference endpoint for a given model creates a ModelDeployment that (i) deploys the model, (ii) is exposed as one or more dcat:DataServices (e.g., REST + gRPC), (iii) runs on a specific it6:ComputerInfrastructure, and (iv) declares an IOContract per exposed service.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#ModelProvider -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#ModelProvider">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pionera/daimo#ParticipantRole"/>
        <rdfs:comment xml:lang="en">Role of an agent that publishes one or more AI models as governed offerings in a dataspace catalog.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">model provider</rdfs:label>
        <skos:definition xml:lang="en">Role of an agent that publishes AI models as governed offerings in a dataspace catalog.</skos:definition>
        <skos:example xml:lang="en">Any organisation that declares one or more AIAssetOfferings under its own authorship and policy holds a ModelProvider role in the dataspace contexts where those offerings are listed.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#ParticipantRole -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#ParticipantRole">
        <rdfs:comment xml:lang="en">A dataspace-scoped role taken by a participant with respect to AI assets. Anti-rigid: an agent can gain and lose roles over time. Subclasses are intentionally NOT mutually disjoint — one agent can hold several roles simultaneously (e.g., a research group may be both Evaluator and Model Provider).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">participant role</rdfs:label>
        <skos:definition xml:lang="en">A dataspace-scoped role played by a participant with respect to AI assets (anti-rigid; an agent gains and loses roles over time).</skos:definition>
        <skos:example xml:lang="en">An agent acting as a Model Provider within a given EDC participant context has a ParticipantRole instance of type ModelProvider connected via daimo:hasRole and scoped by daimo:inParticipantContext.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#PlatformOperator -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#PlatformOperator">
        <rdfs:subClassOf rdf:resource="https://w3id.org/pionera/daimo#ParticipantRole"/>
        <rdfs:comment xml:lang="en">Role of an agent responsible for operating the dataspace runtime, hosting model deployments, and enforcing policy.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">platform operator</rdfs:label>
        <skos:definition xml:lang="en">Role of an agent responsible for operating the dataspace runtime, hosting model deployments, and enforcing policy at runtime.</skos:definition>
        <skos:example xml:lang="en">A dataspace platform provider hosting one or more ModelDeployments, signing AuditEvidence records, and running the EDC connector acts as a PlatformOperator in each participant context it administers.</skos:example>
    </owl:Class>
    


    <!-- https://w3id.org/pionera/daimo#SharedEvaluationContext -->


    <owl:Class rdf:about="https://w3id.org/pionera/daimo#SharedEvaluationContext">
        <rdfs:comment xml:lang="en">A reified grouping of the conditions under which model results are comparable: task, dataset, dataset version, protocol, and random seed. Does not claim to cover every facet that affects comparability (metric, split strategy, hyperparameters); it is the minimum grouping required by CQ-V1..CQ-V3.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/pionera/daimo"/>
        <rdfs:label xml:lang="en">shared evaluation context</rdfs:label>
        <skos:definition xml:lang="en">A reified grouping of the conditions under which model evaluations are comparable: task, dataset, dataset version, evaluation protocol, and random seed.</skos:definition>
        <skos:example xml:lang="en">Two candidate models evaluated on the same SharedEvaluationContext (identical it6:Task, dcat:Dataset, daimo:datasetVersion, daimo:protocol, and daimo:randomSeed) yield metric values that are directly comparable; changing any of the five facets breaks comparability.</skos:example>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // General axioms
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <rdf:Description rdf:about="https://w3id.org/pionera/daimo#AIAssetOffering"/>
            <rdf:Description rdf:about="https://w3id.org/pionera/daimo#AuditEvidence"/>
            <rdf:Description rdf:about="https://w3id.org/pionera/daimo#CrossParticipantProvenanceRecord"/>
            <rdf:Description rdf:about="https://w3id.org/pionera/daimo#DerivedArtifact"/>
            <rdf:Description rdf:about="https://w3id.org/pionera/daimo#ExecutionAuthorization"/>
            <rdf:Description rdf:about="https://w3id.org/pionera/daimo#IOContract"/>
            <rdf:Description rdf:about="https://w3id.org/pionera/daimo#ModelDeployment"/>
            <rdf:Description rdf:about="https://w3id.org/pionera/daimo#ParticipantRole"/>
            <rdf:Description rdf:about="https://w3id.org/pionera/daimo#SharedEvaluationContext"/>
        </owl:members>
        <rdfs:comment xml:lang="en">Asserts that the nine top-level DAIMO-native kinds are pairwise disjoint. ParticipantRole subclasses are deliberately excluded so that a single agent may simultaneously hold several roles (e.g., a research group acting as both Evaluator and Model Provider).</rdfs:comment>
        <rdfs:label xml:lang="en">DAIMO top-level kinds pairwise disjointness</rdfs:label>
    </rdf:Description>
</rdf:RDF>



