<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/pionera/daimo#"
     xml:base="https://w3id.org/pionera/daimo"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/pionera/daimo">
        <owl:versionIRI rdf:resource="https://w3id.org/pionera/daimo/0.1.6"/>
        <terms:conformsTo rdf:resource="https://www.w3.org/TR/owl2-overview/"/>
        <terms:contributor rdf:resource="https://ror.org/03n6nwv02"/>
        <terms:creator rdf:nodeID="genid1"/>
        <terms:creator rdf:nodeID="genid2"/>
        <terms:description xml:lang="en">DAIMO is an integration profile that connects DCAT-AP, MLDCAT-AP, ODRL, PROV-O, and the Dataspace Protocol (DSP, as operationalised by Eclipse EDC) to support publication, discovery, invocation, execution traceability, and contextualised evaluation of AI model assets exchanged in dataspaces. The edc: namespace is used only for EDC-specific extensions (e.g., ParticipantContext) not yet standardised in DSP.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-22</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-06</terms:modified>
        <terms:publisher rdf:resource="https://w3id.org/pionera"/>
        <terms:title xml:lang="en">DAIMO: an ontology for governed AI model assets in dataspaces</terms:title>
        <vann:preferredNamespacePrefix>daimo</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://w3id.org/pionera/daimo#</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="en">See the companion documents ONTOLOGY-REFERENCE.md (class-by-class reference), VALIDATION-MATRIX.md (traceability), and daimo-ontology-design.md (design rationale) in the source repository.</rdfs:comment>
        <rdfs:seeAlso rdf:resource="https://w3id.org/pionera/daimo/align"/>
        <rdfs:seeAlso rdf:resource="https://w3id.org/pionera/daimo/docs"/>
        <rdfs:seeAlso rdf:resource="https://w3id.org/pionera/daimo/shapes"/>
        <owl:priorVersion rdf:resource="https://w3id.org/pionera/daimo/0.1.5"/>
        <owl:versionInfo>0.1.6</owl:versionInfo>
    </owl:Ontology>
    <rdf:Description rdf:nodeID="genid1">
        <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:seeAlso rdf:resource="https://github.com/EdmundoMori"/>
        <foaf:name xml:lang="en">Edmundo de Elvira Mori Orrillo</foaf:name>
    </rdf:Description>
    <rdf:Description rdf:nodeID="genid2">
        <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <foaf:name xml:lang="en">Jiayun Liu</foaf:name>
    </rdf:Description>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/conformsTo -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/conformsTo"/>
    


    <!-- http://purl.org/dc/terms/contributor -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/contributor"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/issued -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/issued"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/modified -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>
    


    <!-- http://purl.org/dc/terms/publisher -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/publisher"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#example -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#example"/>
    


    <!-- http://xmlns.com/foaf/0.1/name -->


    <owl:AnnotationProperty rdf:about="http://xmlns.com/foaf/0.1/name"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://data.europa.eu/it6/hasTask -->


    <owl:ObjectProperty rdf:about="http://data.europa.eu/it6/hasTask"/>
    


    <!-- http://www.w3.org/ns/odrl/2/assignee -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/odrl/2/assignee"/>
    


    <!-- http://www.w3.org/ns/odrl/2/hasPolicy -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/odrl/2/hasPolicy"/>
    


    <!-- http://www.w3.org/ns/prov#wasGeneratedBy -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/prov#wasGeneratedBy"/>
    


    <!-- http://xmlns.com/foaf/0.1/isPrimaryTopicOf -->


    <owl:ObjectProperty rdf:about="http://xmlns.com/foaf/0.1/isPrimaryTopicOf"/>
    


    <!-- http://xmlns.com/foaf/0.1/primaryTopic -->


    <owl:ObjectProperty rdf:about="http://xmlns.com/foaf/0.1/primaryTopic"/>
    


    <!-- https://w3id.org/pionera/daimo#authorizedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#authorizedBy">
        <owl:inverseOf rdf:resource="https://w3id.org/pionera/daimo#authorizesRun"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/it6/Run"/>
        <rdfs:range rdf:resource="https://w3id.org/pionera/daimo#ExecutionAuthorization"/>
        <rdfs:comment xml:lang="en">Inverse of daimo:authorizesRun. Functional: each run is authorized by exactly one agreement.</rdfs:comment>
        <rdfs:label xml:lang="en">authorized by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#authorizesRun -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#authorizesRun">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#ExecutionAuthorization"/>
        <rdfs:range rdf:resource="http://data.europa.eu/it6/Run"/>
        <rdfs:comment xml:lang="en">Links an authorization to a run it permits. Non-functional: a single authorization can cover multiple runs (e.g., subscription-style access). Asymmetric: an authorization is distinct from any run it authorises. Deliberately NOT declared a subproperty of prov:used: an odrl:Agreement is a policy artefact (an Entity), not a prov:Activity; the prov:used domain would incorrectly force ExecutionAuthorization ⊑ prov:Activity.</rdfs:comment>
        <rdfs:label xml:lang="en">authorizes run</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#contextDataset -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#contextDataset">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#SharedEvaluationContext"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
        <rdfs:comment xml:lang="en">The dcat:Dataset the evaluation context is defined over. Functional. Not declared a subproperty of it6:trainedOn because an evaluation-context dataset is an evaluation dataset, not necessarily a training dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">context dataset</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#contextFlow -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#contextFlow">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#SharedEvaluationContext"/>
        <rdfs:range rdf:resource="http://data.europa.eu/it6/Flow"/>
        <rdfs:comment xml:lang="en">The it6:Flow (pipeline / reproducibility artefact) referenced by the evaluation context. Functional. Not declared a subproperty of it6:hasFlow because the evaluation context is not itself a run.</rdfs:comment>
        <rdfs:label xml:lang="en">context flow</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#contextTask -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#contextTask">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/it6/hasTask"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#SharedEvaluationContext"/>
        <rdfs:range rdf:resource="http://data.europa.eu/it6/Task"/>
        <rdfs:comment xml:lang="en">The it6:Task the evaluation context is defined over. Functional.</rdfs:comment>
        <rdfs:label xml:lang="en">context task</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#deploysModel -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#deploysModel">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#ModelDeployment"/>
        <rdfs:range rdf:resource="http://data.europa.eu/it6/MachineLearningModel"/>
        <rdfs:comment xml:lang="en">Links a deployment to the model it serves. Functional: one deployment serves one model. Asymmetric: a deployment and its model are distinct individuals.</rdfs:comment>
        <rdfs:label xml:lang="en">deploys model</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#derivedFromRun -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#derivedFromRun">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasGeneratedBy"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#DerivedArtifact"/>
        <rdfs:range rdf:resource="http://data.europa.eu/it6/Run"/>
        <rdfs:comment xml:lang="en">Links a derived artifact to the run that produced it. Functional: each derived artifact has exactly one originating run. Asymmetric: an artifact and its generating run are distinct.</rdfs:comment>
        <rdfs:label xml:lang="en">derived from run</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#evidenceOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#evidenceOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#AuditEvidence"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">Links audit evidence to the activity it attests. Functional. Asymmetric: audit evidence is distinct from the activity it records. Deliberately NOT declared a subproperty of prov:hadActivity: that property is used on reified influence/generation/usage objects, not on entities — an AuditEvidence is a prov:Entity that is ABOUT an activity, which PROV-O does not provide a direct property for.</rdfs:comment>
        <rdfs:label xml:lang="en">evidence of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#exposedAs -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#exposedAs">
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#ModelDeployment"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#DataService"/>
        <rdfs:comment xml:lang="en">Links a deployment to the DCAT data service(s) that expose it. Non-functional: one deployment may expose multiple endpoints (e.g., a REST service plus a gRPC service, or regional load-balanced endpoints). Each service&apos;s I/O contract can differ (see daimo:hasIOContract, also non-functional).</rdfs:comment>
        <rdfs:label xml:lang="en">exposed as</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#grantedTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#grantedTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/odrl/2/assignee"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#ExecutionAuthorization"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:comment xml:lang="en">Links an authorization to the grantee agent. Functional. Specialises odrl:assignee (the ODRL party receiving an agreement&apos;s terms). Deliberately NOT aligned to prov:qualifiedAssociation: that property points to a reified prov:Association object, not to the agent itself; using it here would incorrectly type every grantee Agent as a prov:Association.</rdfs:comment>
        <rdfs:label xml:lang="en">granted to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#hasAuditEvidence -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#hasAuditEvidence">
        <owl:inverseOf rdf:resource="https://w3id.org/pionera/daimo#evidenceOf"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:range rdf:resource="https://w3id.org/pionera/daimo#AuditEvidence"/>
        <rdfs:comment xml:lang="en">Inverse of daimo:evidenceOf: from an activity, retrieve every audit-evidence record attesting it. Non-functional (multiple auditors can independently attest the same activity).</rdfs:comment>
        <rdfs:label xml:lang="en">has audit evidence</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#hasDeployment -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#hasDeployment">
        <owl:inverseOf rdf:resource="https://w3id.org/pionera/daimo#deploysModel"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/it6/MachineLearningModel"/>
        <rdfs:range rdf:resource="https://w3id.org/pionera/daimo#ModelDeployment"/>
        <rdfs:comment xml:lang="en">Inverse of daimo:deploysModel: from a model, retrieve every deployment that serves it. Non-functional (a model can have multiple deployments across contexts).</rdfs:comment>
        <rdfs:label xml:lang="en">has deployment</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#hasDerivedArtifact -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#hasDerivedArtifact">
        <owl:inverseOf rdf:resource="https://w3id.org/pionera/daimo#derivedFromRun"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/it6/Run"/>
        <rdfs:range rdf:resource="https://w3id.org/pionera/daimo#DerivedArtifact"/>
        <rdfs:comment xml:lang="en">Inverse of daimo:derivedFromRun: from a run, retrieve every derived artifact it produced. Non-functional (a run may produce multiple governed outputs).</rdfs:comment>
        <rdfs:label xml:lang="en">has derived artifact</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#hasIOContract -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#hasIOContract">
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#ModelDeployment"/>
        <rdfs:range rdf:resource="https://w3id.org/pionera/daimo#IOContract"/>
        <rdfs:comment xml:lang="en">Links a deployment to its invocation contract(s). Non-functional: a deployment exposing multiple services (see daimo:exposedAs) may carry a distinct IOContract per protocol (e.g., JSON+OAuth2 for REST and protobuf+mTLS for gRPC).</rdfs:comment>
        <rdfs:label xml:lang="en">has I/O contract</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#hasOfferPolicy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#hasOfferPolicy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/odrl/2/hasPolicy"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#AIAssetOffering"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/odrl/2/Offer"/>
        <rdfs:comment xml:lang="en">Links an offering to the ODRL offer policy that governs the offered model. Functional: each offering carries exactly one canonical offer policy.</rdfs:comment>
        <rdfs:label xml:lang="en">has offer policy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#hasOffering -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#hasOffering">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/isPrimaryTopicOf"/>
        <owl:inverseOf rdf:resource="https://w3id.org/pionera/daimo#offersModel"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/it6/MachineLearningModel"/>
        <rdfs:range rdf:resource="https://w3id.org/pionera/daimo#AIAssetOffering"/>
        <rdfs:comment xml:lang="en">Inverse of daimo:offersModel: from a model, retrieve every catalog offering that registers it. Non-functional (the same model may be offered by different providers in different catalogs). Declared rdfs:subPropertyOf foaf:isPrimaryTopicOf for symmetry with daimo:offersModel ⊑ foaf:primaryTopic.</rdfs:comment>
        <rdfs:label xml:lang="en">has offering</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#hasRole -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#hasRole">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/pionera/daimo#ParticipantRole"/>
        <rdfs:comment xml:lang="en">Links an agent to a dataspace role. Non-functional: agents may hold multiple roles.</rdfs:comment>
        <rdfs:label xml:lang="en">has role</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#inParticipantContext -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#inParticipantContext">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#ParticipantRole"/>
        <rdfs:range rdf:resource="https://w3id.org/edc/v0.0.1/ns/ParticipantContext"/>
        <rdfs:comment xml:lang="en">Scopes a role assignment to a specific EDC participant context. Functional: a role instance is held within exactly one context.</rdfs:comment>
        <rdfs:label xml:lang="en">in participant context</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#inputSchema -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#inputSchema">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#IOContract"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Resource"/>
        <rdfs:comment xml:lang="en">Optional link to a resource describing the input payload schema (JSON Schema, SHACL shape, etc.).</rdfs:comment>
        <rdfs:label xml:lang="en">input schema</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#integrityHash -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#integrityHash">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#AuditEvidence"/>
        <rdfs:range rdf:resource="http://spdx.org/rdf/terms#Checksum"/>
        <rdfs:comment xml:lang="en">Links audit evidence to an spdx:Checksum that bundles the algorithm (spdx:algorithm) and the digest value (spdx:checksumValue). Functional: exactly one canonical checksum per evidence record. A plain-string digest without its algorithm cannot be verified, so a structured spdx:Checksum is required rather than an xsd:string.</rdfs:comment>
        <rdfs:label xml:lang="en">integrity hash</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#offeredBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#offeredBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#AIAssetOffering"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:comment xml:lang="en">Links an offering to the agent that authored the offered AI model (i.e., the model provider). Functional: each offering has exactly one offering agent. Deliberately NOT declared rdfs:subPropertyOf dct:publisher: on a dcat:CatalogRecord, dct:publisher denotes the catalog maintainer (the platform registering the record), not the author of the asset being registered. Conflating them would entail that the catalog-time publisher is the model creator — semantically wrong in a real dataspace where e.g. INESData publishes records authored by UPM.</rdfs:comment>
        <rdfs:label xml:lang="en">offered by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#offersModel -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#offersModel">
        <rdfs:subPropertyOf rdf:resource="http://xmlns.com/foaf/0.1/primaryTopic"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#AIAssetOffering"/>
        <rdfs:range rdf:resource="http://data.europa.eu/it6/MachineLearningModel"/>
        <rdfs:comment xml:lang="en">Links a catalog-record offering to the AI model it registers. Functional: one offering registers exactly one model. Asymmetric: an offering is distinct from the model it offers.</rdfs:comment>
        <rdfs:label xml:lang="en">offers model</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#onInfrastructure -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#onInfrastructure">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#ModelDeployment"/>
        <rdfs:range rdf:resource="http://data.europa.eu/it6/ComputerInfrastructure"/>
        <rdfs:comment xml:lang="en">Links a deployment to the MLDCAT-AP computer infrastructure running it. Functional: one deployment runs on one canonical infrastructure instance (redundancy is modelled as multiple deployments).</rdfs:comment>
        <rdfs:label xml:lang="en">on infrastructure</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#outputSchema -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#outputSchema">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#IOContract"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/dcat#Resource"/>
        <rdfs:comment xml:lang="en">Optional link to a resource describing the output payload schema.</rdfs:comment>
        <rdfs:label xml:lang="en">output schema</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#records -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#records">
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#CrossParticipantProvenanceRecord"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">Links a cross-participant provenance bundle to each prov:Activity that forms part of the audit-ready narrative.</rdfs:comment>
        <rdfs:label xml:lang="en">records</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#signedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#signedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#AuditEvidence"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Agent"/>
        <rdfs:comment xml:lang="en">Functional: one signer per evidence record.</rdfs:comment>
        <rdfs:label xml:lang="en">signed by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#spansParticipantContext -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#spansParticipantContext">
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#CrossParticipantProvenanceRecord"/>
        <rdfs:range rdf:resource="https://w3id.org/edc/v0.0.1/ns/ParticipantContext"/>
        <rdfs:comment xml:lang="en">Links a cross-participant provenance bundle to each participant context whose activities or entities it records. A record must span at least two contexts (enforced by SHACL).</rdfs:comment>
        <rdfs:label xml:lang="en">spans participant context</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#underAuthorization -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#underAuthorization">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#DerivedArtifact"/>
        <rdfs:range rdf:resource="https://w3id.org/pionera/daimo#ExecutionAuthorization"/>
        <rdfs:comment xml:lang="en">Links a derived artifact to the authorisation under which it was produced. Functional.</rdfs:comment>
        <rdfs:label xml:lang="en">under authorization</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/pionera/daimo#usesEvaluationContext -->


    <owl:ObjectProperty rdf:about="https://w3id.org/pionera/daimo#usesEvaluationContext">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://data.europa.eu/it6/Evaluation"/>
        <rdfs:range rdf:resource="https://w3id.org/pionera/daimo#SharedEvaluationContext"/>
        <rdfs:comment xml:lang="en">Links an it6:Evaluation to the shared evaluation context under which its results are comparable to other evaluations. Functional.</rdfs:comment>
        <rdfs:label xml:lang="en">uses evaluation context</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/pionera/daimo#authMethod -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pionera/daimo#authMethod">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#IOContract"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Authentication-method token (e.g. &quot;oauth2-bearer&quot;, &quot;api-key&quot;, &quot;mtls&quot;).</rdfs:comment>
        <rdfs:label xml:lang="en">authentication method</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pionera/daimo#datasetVersion -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pionera/daimo#datasetVersion">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#SharedEvaluationContext"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Literal version identifier of the evaluation dataset used by the context. Deliberately not aligned to dct:hasVersion because dct:hasVersion relates a resource to another version resource, whereas DAIMO records the dataset-version token as a literal for reproducible benchmarking.</rdfs:comment>
        <rdfs:label xml:lang="en">dataset version</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pionera/daimo#expiresAt -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pionera/daimo#expiresAt">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#ExecutionAuthorization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Expiry timestamp of the execution authorisation.</rdfs:comment>
        <rdfs:label xml:lang="en">expires at</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pionera/daimo#inputFormat -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pionera/daimo#inputFormat">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#IOContract"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">IANA media type of the expected input payload (e.g. &quot;application/json&quot;).</rdfs:comment>
        <rdfs:label xml:lang="en">input format</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pionera/daimo#outputFormat -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pionera/daimo#outputFormat">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#IOContract"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">IANA media type of the produced output payload (e.g. &quot;application/geo+json&quot;).</rdfs:comment>
        <rdfs:label xml:lang="en">output format</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pionera/daimo#protocol -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pionera/daimo#protocol">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#SharedEvaluationContext"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the evaluation protocol (e.g. &quot;holdout&quot;, &quot;5-fold-cv&quot;, &quot;bootstrap-1000&quot;).</rdfs:comment>
        <rdfs:label xml:lang="en">evaluation protocol</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pionera/daimo#randomSeed -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pionera/daimo#randomSeed">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#SharedEvaluationContext"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Random seed fixing stochastic components of the protocol, required for reproducibility.</rdfs:comment>
        <rdfs:label xml:lang="en">random seed</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/pionera/daimo#recordedAt -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/pionera/daimo#recordedAt">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/pionera/daimo#AuditEvidence"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Timestamp at which the audit evidence was sealed.</rdfs:comment>
        <rdfs:label xml:lang="en">recorded at</rdfs:label>
    </owl:DatatypeProperty>
    


