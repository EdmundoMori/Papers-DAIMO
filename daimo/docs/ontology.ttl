<https://w3id.org/edc/v0.0.1/ns/ParticipantContext> rdf:type owl:Class .


###  https://w3id.org/pionera/daimo#AIAssetOffering
:AIAssetOffering rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/dcat#CatalogRecord> ;
                 rdfs:comment "A catalog-record entry that registers an AI model in a dataspace catalog, bundling the model reference, the providing agent, and an ODRL offer policy. Specialises dcat:CatalogRecord; carries an odrl:Offer via daimo:hasOfferPolicy. In DSP terms this is the catalog-time artefact that becomes a dspace:ContractOffer during negotiation."@en ;
                 rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                 rdfs:label "AI asset offering"@en ;
                 <http://www.w3.org/2004/02/skos/core#definition> "A catalog-record entry registering an AI model in a dataspace catalog as a governed offer, bundling the model, the issuing agent, and an ODRL offer policy."@en ;
                 <http://www.w3.org/2004/02/skos/core#example> "A research organisation publishing one of its machine-learning models into a dataspace catalog declares an AIAssetOffering that references the model (via offersModel), the organisation itself (via offeredBy), and an ODRL offer policy (via hasOfferPolicy) permitting use and distribution under a specific licence."@en .


###  https://w3id.org/pionera/daimo#AuditEvidence
:AuditEvidence rdf:type owl:Class ;
               rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
               rdfs:comment "A compliance-oriented evidence record attached to a governed event, carrying integrity hash, signer, and timestamp."@en ;
               rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
               rdfs:label "audit evidence"@en ;
               <http://www.w3.org/2004/02/skos/core#definition> "A compliance-oriented evidence record attached to a governed activity, carrying a structured SPDX checksum (algorithm + digest), a signer, and a timestamp."@en ;
               <http://www.w3.org/2004/02/skos/core#example> "For each run of a deployed model, the PlatformOperator produces an AuditEvidence record that references the run (daimo:evidenceOf), carries a structured spdx:Checksum (algorithm + digest) over the run's outputs (daimo:integrityHash), identifies the signer (daimo:signedBy), and timestamps the sealing (daimo:recordedAt)."@en .


###  https://w3id.org/pionera/daimo#CrossParticipantProvenanceRecord
:CrossParticipantProvenanceRecord rdf:type owl:Class ;
                                  rdfs:subClassOf <http://www.w3.org/ns/prov#Bundle> ;
                                  rdfs:comment "A reusable semantic bundle that aggregates prov:Activity and prov:Entity across participant contexts to tell one audit-ready story."@en ;
                                  rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                                  rdfs:label "cross-participant provenance record"@en ;
                                  <http://www.w3.org/2004/02/skos/core#definition> "A PROV bundle that aggregates activities and entities spanning at least two EDC participant contexts, forming an audit-ready cross-participant provenance narrative."@en ;
                                  <http://www.w3.org/2004/02/skos/core#example> "When a derived artefact is produced by a consumer invoking a provider's model hosted by a third-party operator, a CrossParticipantProvenanceRecord aggregates the relevant activities across the provider, consumer, and operator participant contexts into one bundle for audit."@en .


###  https://w3id.org/pionera/daimo#DerivedArtifact
:DerivedArtifact rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/dcat#Resource> ,
                                 <http://www.w3.org/ns/prov#Entity> ;
                 rdfs:comment "A governed, catalog-describable output produced by an it6:Run in a dataspace context, bearing its own provenance and policy."@en ;
                 rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                 rdfs:label "derived artifact"@en ;
                 <http://www.w3.org/2004/02/skos/core#definition> "A governed, catalog-describable output produced by a run in a dataspace context, carrying its own provenance pointer and authorisation pointer."@en ;
                 <http://www.w3.org/2004/02/skos/core#example> "When a consumer invokes a deployed model, the run's output (a prediction dataset, a classification result, a generated artefact) is typed as a DerivedArtifact that points back to the producing run (daimo:derivedFromRun) and to the authorisation under which it was produced (daimo:underAuthorization)."@en .


###  https://w3id.org/pionera/daimo#Evaluator
:Evaluator rdf:type owl:Class ;
           rdfs:subClassOf :ParticipantRole ;
           rdfs:comment "Role of an agent that evaluates or compares AI models under a shared evaluation context."@en ;
           rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
           rdfs:label "evaluator"@en ;
           <http://www.w3.org/2004/02/skos/core#definition> "Role of an agent that evaluates or compares AI models under a shared evaluation context."@en ;
           <http://www.w3.org/2004/02/skos/core#example> "Any agent that produces it6:Evaluation instances linked to a shared SharedEvaluationContext (via daimo:usesEvaluationContext) holds an Evaluator role — for example, a benchmarking team comparing candidate models on the same dataset version and seed."@en .


###  https://w3id.org/pionera/daimo#ExecutionAuthorization
:ExecutionAuthorization rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.w3.org/ns/odrl/2/Agreement> ;
                        rdfs:comment "An ODRL agreement (produced by a DSP contract negotiation) that binds at least one odrl:permission to concrete it6:Run invocations it authorises. Specialises odrl:Agreement; MUST carry at least one odrl:permission per the ODRL policy model."@en ;
                        rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                        rdfs:label "execution authorization"@en ;
                        <http://www.w3.org/2004/02/skos/core#definition> "An ODRL agreement, produced by a Dataspace-Protocol contract negotiation, that binds specific ODRL permissions to concrete MLDCAT-AP run invocations it authorises, with an expiry timestamp and a grantee agent."@en ;
                        <http://www.w3.org/2004/02/skos/core#example> "After a successful DSP contract negotiation, the resulting agreement is represented as an ExecutionAuthorization granting odrl:use to the consumer (daimo:grantedTo), covering one or more runs via daimo:authorizesRun, expiring at a specified daimo:expiresAt timestamp."@en .


###  https://w3id.org/pionera/daimo#GovernanceActor
:GovernanceActor rdf:type owl:Class ;
                 rdfs:subClassOf :ParticipantRole ;
                 rdfs:comment "Role of an agent that audits execution evidence, enforces compliance obligations, and validates governance across the dataspace."@en ;
                 rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                 rdfs:label "governance actor"@en ;
                 <http://www.w3.org/2004/02/skos/core#definition> "Role of an agent that audits execution evidence, enforces compliance obligations, and validates governance across the dataspace."@en ;
                 <http://www.w3.org/2004/02/skos/core#example> "An external compliance body that reads CrossParticipantProvenanceRecord bundles and AuditEvidence records to verify lawful execution holds a GovernanceActor role — for example, a regulator or a conformance-labelling body."@en .


###  https://w3id.org/pionera/daimo#IOContract
:IOContract rdf:type owl:Class ;
            rdfs:comment "The minimum machine-actionable invocation contract for a deployment: input format, output format, authentication method, and optional input/output schemas."@en ;
            rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
            rdfs:label "I/O contract"@en ;
            <http://www.w3.org/2004/02/skos/core#definition> "The minimum machine-actionable invocation contract for a deployment endpoint: input media type, output media type, authentication method, and optional input/output schemas."@en ;
            <http://www.w3.org/2004/02/skos/core#example> "A REST inference endpoint might declare an IOContract with inputFormat \"application/json\", outputFormat \"application/geo+json\", and authMethod \"oauth2-bearer\"; a parallel gRPC endpoint on the same deployment can declare a second IOContract with inputFormat \"application/x-protobuf\" and authMethod \"mtls\"."@en .


###  https://w3id.org/pionera/daimo#ModelConsumer
:ModelConsumer rdf:type owl:Class ;
               rdfs:subClassOf :ParticipantRole ;
               rdfs:comment "Role of an agent that discovers, negotiates, and invokes AI models offered by a Model Provider."@en ;
               rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
               rdfs:label "model consumer"@en ;
               <http://www.w3.org/2004/02/skos/core#definition> "Role of an agent that discovers, negotiates access to, and invokes AI models offered by a Model Provider."@en ;
               <http://www.w3.org/2004/02/skos/core#example> "Any agent that receives an ExecutionAuthorization (via daimo:grantedTo) and uses it to invoke runs of a deployed model holds a ModelConsumer role within the corresponding participant context."@en .


###  https://w3id.org/pionera/daimo#ModelDeployment
:ModelDeployment rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                 rdfs:comment "A running or hosted instance of an MLDCAT-AP MachineLearningModel exposed through a dcat:DataService under an operational environment."@en ;
                 rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                 rdfs:label "model deployment"@en ;
                 <http://www.w3.org/2004/02/skos/core#definition> "A running or hosted instance of a machine-learning model exposed through one or more DCAT data services over a named compute infrastructure, under a per-service I/O contract."@en ;
                 <http://www.w3.org/2004/02/skos/core#example> "A PlatformOperator that stands up a live inference endpoint for a given model creates a ModelDeployment that (i) deploys the model, (ii) is exposed as one or more dcat:DataServices (e.g., REST + gRPC), (iii) runs on a specific it6:ComputerInfrastructure, and (iv) declares an IOContract per exposed service."@en .


###  https://w3id.org/pionera/daimo#ModelProvider
:ModelProvider rdf:type owl:Class ;
               rdfs:subClassOf :ParticipantRole ;
               rdfs:comment "Role of an agent that publishes one or more AI models as governed offerings in a dataspace catalog."@en ;
               rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
               rdfs:label "model provider"@en ;
               <http://www.w3.org/2004/02/skos/core#definition> "Role of an agent that publishes AI models as governed offerings in a dataspace catalog."@en ;
               <http://www.w3.org/2004/02/skos/core#example> "Any organisation that declares one or more AIAssetOfferings under its own authorship and policy holds a ModelProvider role in the dataspace contexts where those offerings are listed."@en .


###  https://w3id.org/pionera/daimo#ParticipantRole
:ParticipantRole rdf:type owl:Class ;
                 rdfs:comment "A dataspace-scoped role taken by a participant with respect to AI assets. Anti-rigid: an agent can gain and lose roles over time. Subclasses are intentionally NOT mutually disjoint — one agent can hold several roles simultaneously (e.g., a research group may be both Evaluator and Model Provider)."@en ;
                 rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                 rdfs:label "participant role"@en ;
                 <http://www.w3.org/2004/02/skos/core#definition> "A dataspace-scoped role played by a participant with respect to AI assets (anti-rigid; an agent gains and loses roles over time)."@en ;
                 <http://www.w3.org/2004/02/skos/core#example> "An agent acting as a Model Provider within a given EDC participant context has a ParticipantRole instance of type ModelProvider connected via daimo:hasRole and scoped by daimo:inParticipantContext."@en .


###  https://w3id.org/pionera/daimo#PlatformOperator
:PlatformOperator rdf:type owl:Class ;
                  rdfs:subClassOf :ParticipantRole ;
                  rdfs:comment "Role of an agent responsible for operating the dataspace runtime, hosting model deployments, and enforcing policy."@en ;
                  rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                  rdfs:label "platform operator"@en ;
                  <http://www.w3.org/2004/02/skos/core#definition> "Role of an agent responsible for operating the dataspace runtime, hosting model deployments, and enforcing policy at runtime."@en ;
                  <http://www.w3.org/2004/02/skos/core#example> "A dataspace platform provider hosting one or more ModelDeployments, signing AuditEvidence records, and running the EDC connector acts as a PlatformOperator in each participant context it administers."@en .


###  https://w3id.org/pionera/daimo#SharedEvaluationContext
:SharedEvaluationContext rdf:type owl:Class ;
                         rdfs:comment "A reified grouping of the conditions under which model results are comparable: task, dataset, dataset version, protocol, and random seed. Does not claim to cover every facet that affects comparability (metric, split strategy, hyperparameters); it is the minimum grouping required by CQ-V1..CQ-V3."@en ;
                         rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                         rdfs:label "shared evaluation context"@en ;
                         <http://www.w3.org/2004/02/skos/core#definition> "A reified grouping of the conditions under which model evaluations are comparable: task, dataset, dataset version, evaluation protocol, and random seed."@en ;
                         <http://www.w3.org/2004/02/skos/core#example> "Two candidate models evaluated on the same SharedEvaluationContext (identical it6:Task, dcat:Dataset, daimo:datasetVersion, daimo:protocol, and daimo:randomSeed) yield metric values that are directly comparable; changing any of the five facets breaks comparability."@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :AIAssetOffering
                :AuditEvidence
                :CrossParticipantProvenanceRecord
                :DerivedArtifact
                :ExecutionAuthorization
                :IOContract
                :ModelDeployment
                :ParticipantRole
                :SharedEvaluationContext
              ) ;
  rdfs:comment "Asserts that the nine top-level DAIMO-native kinds are pairwise disjoint. ParticipantRole subclasses are deliberately excluded so that a single agent may simultaneously hold several roles (e.g., a research group acting as both Evaluator and Model Provider)."@en ;
  rdfs:label "DAIMO top-level kinds pairwise disjointness"@en
] .


