@prefix daimo: <https://w3id.org/pionera/daimo#> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dspace: <https://w3id.org/dspace/v0.8/> .
@prefix edc: <https://w3id.org/edc/v0.0.1/ns/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix it6: <http://data.europa.eu/it6/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix spdx: <http://spdx.org/rdf/terms#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

it6:hasFlow a owl:ObjectProperty ;
    rdfs:label "has flow"@en ;
    rdfs:comment "MLDCAT-AP: links a run to the flow (pipeline) that defines it."@en ;
    rdfs:domain it6:Run ;
    rdfs:isDefinedBy it6: ;
    rdfs:range it6:Flow .

it6:trainedOn a owl:ObjectProperty ;
    rdfs:label "trained on"@en ;
    rdfs:comment "MLDCAT-AP: links a machine-learning model to the dataset it was trained on."@en ;
    rdfs:domain it6:MachineLearningModel ;
    rdfs:isDefinedBy it6: ;
    rdfs:range dcat:Dataset .

dct:hasVersion a owl:ObjectProperty ;
    rdfs:label "has version"@en ;
    rdfs:comment "Dublin Core: a related resource that is a version, edition, or adaptation of the described resource."@en ;
    rdfs:domain owl:Thing ;
    rdfs:isDefinedBy dct: ;
    rdfs:range owl:Thing .

dct:publisher a owl:ObjectProperty ;
    rdfs:label "publisher"@en ;
    rdfs:comment "Dublin Core: entity responsible for making the resource available."@en ;
    rdfs:domain owl:Thing ;
    rdfs:isDefinedBy dct: ;
    rdfs:range foaf:Agent .

spdx:algorithm a owl:ObjectProperty ;
    rdfs:label "checksum algorithm"@en ;
    rdfs:comment "SPDX: identifies the algorithm used to compute a checksum (e.g., spdx:checksumAlgorithm_sha256)."@en ;
    rdfs:domain spdx:Checksum ;
    rdfs:isDefinedBy spdx: ;
    rdfs:range owl:Thing .

spdx:checksumValue a owl:DatatypeProperty ;
    rdfs:label "checksum value"@en ;
    rdfs:comment "SPDX: the hexadecimal digest computed by the algorithm."@en ;
    rdfs:domain spdx:Checksum ;
    rdfs:isDefinedBy spdx: ;
    rdfs:range xsd:string .

dcat:Catalog a owl:Class ;
    rdfs:label "Catalog"@en ;
    rdfs:comment "DCAT: a curated collection of metadata about resources."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/dcat> ;
    rdfs:seeAlso <https://www.w3.org/TR/vocab-dcat-2/#Class:Catalog> .

dcat:Distribution a owl:Class ;
    rdfs:label "Distribution"@en ;
    rdfs:comment "DCAT: a specific representation of a dataset (e.g., a file, feed, or API)."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/dcat> ;
    rdfs:seeAlso <https://www.w3.org/TR/vocab-dcat-2/#Class:Distribution> .

odrl:Permission a owl:Class ;
    rdfs:label "Permission"@en ;
    rdfs:comment "ODRL: a rule permitting an action on an asset, optionally subject to constraints and duties."@en ;
    rdfs:isDefinedBy odrl: ;
    rdfs:seeAlso <https://www.w3.org/TR/odrl-model/#rule-permission> .

prov:hadActivity a owl:ObjectProperty ;
    rdfs:label "had activity"@en ;
    rdfs:comment "PROV-O: links a qualified influence, association, or similar to an activity."@en ;
    rdfs:domain owl:Thing ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
    rdfs:range prov:Activity .

prov:qualifiedAssociation a owl:ObjectProperty ;
    rdfs:label "qualified association"@en ;
    rdfs:comment "PROV-O: a qualified association between an activity and an agent."@en ;
    rdfs:domain prov:Activity ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
    rdfs:range prov:Association .

prov:used a owl:ObjectProperty ;
    rdfs:label "used"@en ;
    rdfs:comment "PROV-O: an activity used an entity."@en ;
    rdfs:domain prov:Activity ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
    rdfs:range prov:Entity .

daimo:Evaluator a owl:Class ;
    rdfs:label "evaluator"@en ;
    rdfs:comment "Role of an agent that evaluates or compares AI models under a shared evaluation context."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf daimo:ParticipantRole ;
    skos:definition "Role of an agent that evaluates or compares AI models under a shared evaluation context."@en ;
    skos:example "Any agent that produces it6:Evaluation instances linked to a shared SharedEvaluationContext (via daimo:usesEvaluationContext) holds an Evaluator role — for example, a benchmarking team comparing candidate models on the same dataset version and seed."@en .

daimo:GovernanceActor a owl:Class ;
    rdfs:label "governance actor"@en ;
    rdfs:comment "Role of an agent that audits execution evidence, enforces compliance obligations, and validates governance across the dataspace."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf daimo:ParticipantRole ;
    skos:definition "Role of an agent that audits execution evidence, enforces compliance obligations, and validates governance across the dataspace."@en ;
    skos:example "An external compliance body that reads CrossParticipantProvenanceRecord bundles and AuditEvidence records to verify lawful execution holds a GovernanceActor role — for example, a regulator or a conformance-labelling body."@en .

daimo:ModelConsumer a owl:Class ;
    rdfs:label "model consumer"@en ;
    rdfs:comment "Role of an agent that discovers, negotiates, and invokes AI models offered by a Model Provider."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf daimo:ParticipantRole ;
    skos:definition "Role of an agent that discovers, negotiates access to, and invokes AI models offered by a Model Provider."@en ;
    skos:example "Any agent that receives an ExecutionAuthorization (via daimo:grantedTo) and uses it to invoke runs of a deployed model holds a ModelConsumer role within the corresponding participant context."@en .

daimo:ModelProvider a owl:Class ;
    rdfs:label "model provider"@en ;
    rdfs:comment "Role of an agent that publishes one or more AI models as governed offerings in a dataspace catalog."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf daimo:ParticipantRole ;
    skos:definition "Role of an agent that publishes AI models as governed offerings in a dataspace catalog."@en ;
    skos:example "Any organisation that declares one or more AIAssetOfferings under its own authorship and policy holds a ModelProvider role in the dataspace contexts where those offerings are listed."@en .

daimo:PlatformOperator a owl:Class ;
    rdfs:label "platform operator"@en ;
    rdfs:comment "Role of an agent responsible for operating the dataspace runtime, hosting model deployments, and enforcing policy."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf daimo:ParticipantRole ;
    skos:definition "Role of an agent responsible for operating the dataspace runtime, hosting model deployments, and enforcing policy at runtime."@en ;
    skos:example "A dataspace platform provider hosting one or more ModelDeployments, signing AuditEvidence records, and running the EDC connector acts as a PlatformOperator in each participant context it administers."@en .

daimo:TopLevelKindsDisjointness a owl:AllDisjointClasses ;
    rdfs:label "DAIMO top-level kinds pairwise disjointness"@en ;
    rdfs:comment "Asserts that the nine top-level DAIMO-native kinds are pairwise disjoint. ParticipantRole subclasses are deliberately excluded so that a single agent may simultaneously hold several roles (e.g., a research group acting as both Evaluator and Model Provider)."@en ;
    owl:members ( daimo:AIAssetOffering daimo:ParticipantRole daimo:ModelDeployment daimo:IOContract daimo:ExecutionAuthorization daimo:DerivedArtifact daimo:AuditEvidence daimo:SharedEvaluationContext daimo:CrossParticipantProvenanceRecord ) .

daimo:authMethod a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "authentication method"@en ;
    rdfs:comment "Authentication-method token (e.g. \"oauth2-bearer\", \"api-key\", \"mtls\")."@en ;
    rdfs:domain daimo:IOContract ;
    rdfs:range xsd:string .

daimo:authorizedBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "authorized by"@en ;
    rdfs:comment "Inverse of daimo:authorizesRun. Functional: each run is authorized by exactly one agreement."@en ;
    rdfs:domain it6:Run ;
    rdfs:range daimo:ExecutionAuthorization ;
    owl:inverseOf daimo:authorizesRun .

daimo:contextDataset a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "context dataset"@en ;
    rdfs:comment "The dcat:Dataset the evaluation context is defined over. Functional. Not declared a subproperty of it6:trainedOn because an evaluation-context dataset is an evaluation dataset, not necessarily a training dataset."@en ;
    rdfs:domain daimo:SharedEvaluationContext ;
    rdfs:range dcat:Dataset .

daimo:contextFlow a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "context flow"@en ;
    rdfs:comment "The it6:Flow (pipeline / reproducibility artefact) referenced by the evaluation context. Functional. Not declared a subproperty of it6:hasFlow because the evaluation context is not itself a run."@en ;
    rdfs:domain daimo:SharedEvaluationContext ;
    rdfs:range it6:Flow .

daimo:contextTask a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "context task"@en ;
    rdfs:comment "The it6:Task the evaluation context is defined over. Functional."@en ;
    rdfs:domain daimo:SharedEvaluationContext ;
    rdfs:range it6:Task ;
    rdfs:subPropertyOf it6:hasTask .

daimo:datasetVersion a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "dataset version"@en ;
    rdfs:comment "Literal version identifier of the evaluation dataset used by the context. Deliberately not aligned to dct:hasVersion because dct:hasVersion relates a resource to another version resource, whereas DAIMO records the dataset-version token as a literal for reproducible benchmarking."@en ;
    rdfs:domain daimo:SharedEvaluationContext ;
    rdfs:range xsd:string .

daimo:expiresAt a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "expires at"@en ;
    rdfs:comment "Expiry timestamp of the execution authorisation."@en ;
    rdfs:domain daimo:ExecutionAuthorization ;
    rdfs:range xsd:dateTime .

daimo:exposedAs a owl:ObjectProperty ;
    rdfs:label "exposed as"@en ;
    rdfs:comment "Links a deployment to the DCAT data service(s) that expose it. Non-functional: one deployment may expose multiple endpoints (e.g., a REST service plus a gRPC service, or regional load-balanced endpoints). Each service's I/O contract can differ (see daimo:hasIOContract, also non-functional)."@en ;
    rdfs:domain daimo:ModelDeployment ;
    rdfs:range dcat:DataService .

daimo:grantedTo a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "granted to"@en ;
    rdfs:comment "Links an authorization to the grantee agent. Functional. Specialises odrl:assignee (the ODRL party receiving an agreement's terms). Deliberately NOT aligned to prov:qualifiedAssociation: that property points to a reified prov:Association object, not to the agent itself; using it here would incorrectly type every grantee Agent as a prov:Association."@en ;
    rdfs:domain daimo:ExecutionAuthorization ;
    rdfs:range foaf:Agent ;
    rdfs:subPropertyOf odrl:assignee .

daimo:hasAuditEvidence a owl:ObjectProperty ;
    rdfs:label "has audit evidence"@en ;
    rdfs:comment "Inverse of daimo:evidenceOf: from an activity, retrieve every audit-evidence record attesting it. Non-functional (multiple auditors can independently attest the same activity)."@en ;
    rdfs:domain prov:Activity ;
    rdfs:range daimo:AuditEvidence ;
    owl:inverseOf daimo:evidenceOf .

daimo:hasDeployment a owl:ObjectProperty ;
    rdfs:label "has deployment"@en ;
    rdfs:comment "Inverse of daimo:deploysModel: from a model, retrieve every deployment that serves it. Non-functional (a model can have multiple deployments across contexts)."@en ;
    rdfs:domain it6:MachineLearningModel ;
    rdfs:range daimo:ModelDeployment ;
    owl:inverseOf daimo:deploysModel .

daimo:hasDerivedArtifact a owl:ObjectProperty ;
    rdfs:label "has derived artifact"@en ;
    rdfs:comment "Inverse of daimo:derivedFromRun: from a run, retrieve every derived artifact it produced. Non-functional (a run may produce multiple governed outputs)."@en ;
    rdfs:domain it6:Run ;
    rdfs:range daimo:DerivedArtifact ;
    owl:inverseOf daimo:derivedFromRun .

daimo:hasIOContract a owl:ObjectProperty ;
    rdfs:label "has I/O contract"@en ;
    rdfs:comment "Links a deployment to its invocation contract(s). Non-functional: a deployment exposing multiple services (see daimo:exposedAs) may carry a distinct IOContract per protocol (e.g., JSON+OAuth2 for REST and protobuf+mTLS for gRPC)."@en ;
    rdfs:domain daimo:ModelDeployment ;
    rdfs:range daimo:IOContract .

daimo:hasOfferPolicy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has offer policy"@en ;
    rdfs:comment "Links an offering to the ODRL offer policy that governs the offered model. Functional: each offering carries exactly one canonical offer policy."@en ;
    rdfs:domain daimo:AIAssetOffering ;
    rdfs:range odrl:Offer ;
    rdfs:subPropertyOf odrl:hasPolicy .

daimo:hasOffering a owl:ObjectProperty ;
    rdfs:label "has offering"@en ;
    rdfs:comment "Inverse of daimo:offersModel: from a model, retrieve every catalog offering that registers it. Non-functional (the same model may be offered by different providers in different catalogs). Declared rdfs:subPropertyOf foaf:isPrimaryTopicOf for symmetry with daimo:offersModel ⊑ foaf:primaryTopic."@en ;
    rdfs:domain it6:MachineLearningModel ;
    rdfs:range daimo:AIAssetOffering ;
    rdfs:subPropertyOf foaf:isPrimaryTopicOf ;
    owl:inverseOf daimo:offersModel .

daimo:hasRole a owl:ObjectProperty ;
    rdfs:label "has role"@en ;
    rdfs:comment "Links an agent to a dataspace role. Non-functional: agents may hold multiple roles."@en ;
    rdfs:domain foaf:Agent ;
    rdfs:range daimo:ParticipantRole .

daimo:inParticipantContext a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "in participant context"@en ;
    rdfs:comment "Scopes a role assignment to a specific EDC participant context. Functional: a role instance is held within exactly one context."@en ;
    rdfs:domain daimo:ParticipantRole ;
    rdfs:range edc:ParticipantContext ;
    skos:related edc:ParticipantContext .

daimo:inputFormat a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "input format"@en ;
    rdfs:comment "IANA media type of the expected input payload (e.g. \"application/json\")."@en ;
    rdfs:domain daimo:IOContract ;
    rdfs:range xsd:string .

daimo:inputSchema a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "input schema"@en ;
    rdfs:comment "Optional link to a resource describing the input payload schema (JSON Schema, SHACL shape, etc.)."@en ;
    rdfs:domain daimo:IOContract ;
    rdfs:range dcat:Resource .

daimo:integrityHash a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "integrity hash"@en ;
    rdfs:comment "Links audit evidence to an spdx:Checksum that bundles the algorithm (spdx:algorithm) and the digest value (spdx:checksumValue). Functional: exactly one canonical checksum per evidence record. A plain-string digest without its algorithm cannot be verified, so a structured spdx:Checksum is required rather than an xsd:string."@en ;
    rdfs:domain daimo:AuditEvidence ;
    rdfs:range spdx:Checksum .

daimo:offeredBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "offered by"@en ;
    rdfs:comment "Links an offering to the agent that authored the offered AI model (i.e., the model provider). Functional: each offering has exactly one offering agent. Deliberately NOT declared rdfs:subPropertyOf dct:publisher: on a dcat:CatalogRecord, dct:publisher denotes the catalog maintainer (the platform registering the record), not the author of the asset being registered. Conflating them would entail that the catalog-time publisher is the model creator — semantically wrong in a real dataspace where e.g. INESData publishes records authored by UPM."@en ;
    rdfs:domain daimo:AIAssetOffering ;
    rdfs:range foaf:Agent .

daimo:onInfrastructure a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "on infrastructure"@en ;
    rdfs:comment "Links a deployment to the MLDCAT-AP computer infrastructure running it. Functional: one deployment runs on one canonical infrastructure instance (redundancy is modelled as multiple deployments)."@en ;
    rdfs:domain daimo:ModelDeployment ;
    rdfs:range it6:ComputerInfrastructure .

daimo:outputFormat a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "output format"@en ;
    rdfs:comment "IANA media type of the produced output payload (e.g. \"application/geo+json\")."@en ;
    rdfs:domain daimo:IOContract ;
    rdfs:range xsd:string .

daimo:outputSchema a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "output schema"@en ;
    rdfs:comment "Optional link to a resource describing the output payload schema."@en ;
    rdfs:domain daimo:IOContract ;
    rdfs:range dcat:Resource .

daimo:protocol a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "evaluation protocol"@en ;
    rdfs:comment "Name of the evaluation protocol (e.g. \"holdout\", \"5-fold-cv\", \"bootstrap-1000\")."@en ;
    rdfs:domain daimo:SharedEvaluationContext ;
    rdfs:range xsd:string .

daimo:randomSeed a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "random seed"@en ;
    rdfs:comment "Random seed fixing stochastic components of the protocol, required for reproducibility."@en ;
    rdfs:domain daimo:SharedEvaluationContext ;
    rdfs:range xsd:integer .

daimo:recordedAt a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "recorded at"@en ;
    rdfs:comment "Timestamp at which the audit evidence was sealed."@en ;
    rdfs:domain daimo:AuditEvidence ;
    rdfs:range xsd:dateTime .

daimo:records a owl:ObjectProperty ;
    rdfs:label "records"@en ;
    rdfs:comment "Links a cross-participant provenance bundle to each prov:Activity that forms part of the audit-ready narrative."@en ;
    rdfs:domain daimo:CrossParticipantProvenanceRecord ;
    rdfs:range prov:Activity .

daimo:signedBy a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "signed by"@en ;
    rdfs:comment "Functional: one signer per evidence record."@en ;
    rdfs:domain daimo:AuditEvidence ;
    rdfs:range foaf:Agent .

daimo:spansParticipantContext a owl:ObjectProperty ;
    rdfs:label "spans participant context"@en ;
    rdfs:comment "Links a cross-participant provenance bundle to each participant context whose activities or entities it records. A record must span at least two contexts (enforced by SHACL)."@en ;
    rdfs:domain daimo:CrossParticipantProvenanceRecord ;
    rdfs:range edc:ParticipantContext ;
    skos:related edc:ParticipantContext .

daimo:underAuthorization a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "under authorization"@en ;
    rdfs:comment "Links a derived artifact to the authorisation under which it was produced. Functional."@en ;
    rdfs:domain daimo:DerivedArtifact ;
    rdfs:range daimo:ExecutionAuthorization .

daimo:usesEvaluationContext a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "uses evaluation context"@en ;
    rdfs:comment "Links an it6:Evaluation to the shared evaluation context under which its results are comparable to other evaluations. Functional."@en ;
    rdfs:domain it6:Evaluation ;
    rdfs:range daimo:SharedEvaluationContext .

it6:ComputerInfrastructure a owl:Class ;
    rdfs:label "Computer Infrastructure"@en ;
    rdfs:comment "MLDCAT-AP: a named environment bundling hardware and libraries used to run a model."@en ;
    rdfs:isDefinedBy it6: ;
    rdfs:seeAlso <https://semiceu.github.io/MLDCAT-AP/releases/3.0.0/#ComputerInfrastructure> .

it6:Evaluation a owl:Class ;
    rdfs:label "Evaluation"@en ;
    rdfs:comment "MLDCAT-AP: an evaluation of a model, carrying one or more evaluation measures."@en ;
    rdfs:isDefinedBy it6: ;
    rdfs:seeAlso <https://semiceu.github.io/MLDCAT-AP/releases/3.0.0/#Evaluation> .

it6:hasTask a owl:ObjectProperty ;
    rdfs:label "has task"@en ;
    rdfs:comment "MLDCAT-AP: links a model or evaluation to the task it addresses."@en ;
    rdfs:domain owl:Thing ;
    rdfs:isDefinedBy it6: ;
    rdfs:range it6:Task .

dcat:CatalogRecord a owl:Class ;
    rdfs:label "Catalog Record"@en ;
    rdfs:comment "DCAT: a record in a data catalog describing the registration of a single dataset or data service."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/dcat> ;
    rdfs:seeAlso <https://www.w3.org/TR/vocab-dcat-2/#Class:Catalog_Record> .

dcat:DataService a owl:Class ;
    rdfs:label "Data Service"@en ;
    rdfs:comment "DCAT: a site or end-point providing operations related to the discovery of, access to, or processing functions on, data or related resources."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/dcat> ;
    rdfs:seeAlso <https://www.w3.org/TR/vocab-dcat-2/#Class:Data_Service> .

odrl:Agreement a owl:Class ;
    rdfs:label "Agreement"@en ;
    rdfs:comment "ODRL: a policy asserting an agreement between assigner and assignee over a target asset."@en ;
    rdfs:isDefinedBy odrl: ;
    rdfs:seeAlso <https://www.w3.org/TR/odrl-model/#policy-agreement> .

odrl:Offer a owl:Class ;
    rdfs:label "Offer"@en ;
    rdfs:comment "ODRL: a policy asserting offer terms over a target asset, by an assigner, comprising permissions, prohibitions, and duties."@en ;
    rdfs:isDefinedBy odrl: ;
    rdfs:seeAlso <https://www.w3.org/TR/odrl-model/#policy-offer> .

odrl:Party a owl:Class ;
    rdfs:label "Party"@en ;
    rdfs:comment "ODRL: an entity that plays a role (assigner, assignee) in a policy."@en ;
    rdfs:isDefinedBy odrl: .

odrl:assignee a owl:ObjectProperty ;
    rdfs:label "assignee"@en ;
    rdfs:comment "ODRL: the party receiving the policy rules."@en ;
    rdfs:domain odrl:Policy ;
    rdfs:isDefinedBy odrl: ;
    rdfs:range odrl:Party .

odrl:hasPolicy a owl:ObjectProperty ;
    rdfs:label "has policy"@en ;
    rdfs:comment "ODRL: attaches an ODRL policy to a resource. Range restricted to odrl:Policy."@en ;
    rdfs:domain owl:Thing ;
    rdfs:isDefinedBy odrl: ;
    rdfs:range odrl:Policy .

prov:Association a owl:Class ;
    rdfs:label "Association"@en ;
    rdfs:comment "PROV-O: an assignment of responsibility to an agent for an activity, indicating that the agent had a role in the activity."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> .

prov:Bundle a owl:Class ;
    rdfs:label "Bundle"@en ;
    rdfs:comment "PROV-O: a named set of provenance descriptions that is itself an entity."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
    rdfs:seeAlso <https://www.w3.org/TR/prov-o/#Bundle> .

prov:Role a owl:Class ;
    rdfs:label "Role"@en ;
    rdfs:comment "PROV-O: a description of the part played by an entity or agent in an activity."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
    rdfs:seeAlso <https://www.w3.org/TR/prov-o/#Role> .

prov:wasGeneratedBy a owl:ObjectProperty ;
    rdfs:label "was generated by"@en ;
    rdfs:comment "PROV-O: an entity was generated by an activity."@en ;
    rdfs:domain prov:Entity ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
    rdfs:range prov:Activity .

foaf:isPrimaryTopicOf a owl:ObjectProperty ;
    rdfs:label "is primary topic of"@en ;
    rdfs:comment "FOAF: inverse of foaf:primaryTopic. Links a resource to a document whose primary topic it is."@en ;
    rdfs:domain owl:Thing ;
    rdfs:isDefinedBy foaf: ;
    rdfs:range owl:Thing ;
    rdfs:seeAlso <http://xmlns.com/foaf/spec/#term_isPrimaryTopicOf> .

foaf:primaryTopic a owl:ObjectProperty ;
    rdfs:label "primary topic"@en ;
    rdfs:comment "FOAF: the primary topic of some document."@en ;
    rdfs:domain owl:Thing ;
    rdfs:isDefinedBy foaf: ;
    rdfs:range owl:Thing ;
    rdfs:seeAlso <http://xmlns.com/foaf/spec/#term_primaryTopic> .

daimo:authorizesRun a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "authorizes run"@en ;
    rdfs:comment "Links an authorization to a run it permits. Non-functional: a single authorization can cover multiple runs (e.g., subscription-style access). Asymmetric: an authorization is distinct from any run it authorises. Deliberately NOT declared a subproperty of prov:used: an odrl:Agreement is a policy artefact (an Entity), not a prov:Activity; the prov:used domain would incorrectly force ExecutionAuthorization ⊑ prov:Activity."@en ;
    rdfs:domain daimo:ExecutionAuthorization ;
    rdfs:range it6:Run .

daimo:deploysModel a owl:AsymmetricProperty,
        owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "deploys model"@en ;
    rdfs:comment "Links a deployment to the model it serves. Functional: one deployment serves one model. Asymmetric: a deployment and its model are distinct individuals."@en ;
    rdfs:domain daimo:ModelDeployment ;
    rdfs:range it6:MachineLearningModel .

daimo:derivedFromRun a owl:AsymmetricProperty,
        owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "derived from run"@en ;
    rdfs:comment "Links a derived artifact to the run that produced it. Functional: each derived artifact has exactly one originating run. Asymmetric: an artifact and its generating run are distinct."@en ;
    rdfs:domain daimo:DerivedArtifact ;
    rdfs:range it6:Run ;
    rdfs:subPropertyOf prov:wasGeneratedBy .

daimo:evidenceOf a owl:AsymmetricProperty,
        owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "evidence of"@en ;
    rdfs:comment "Links audit evidence to the activity it attests. Functional. Asymmetric: audit evidence is distinct from the activity it records. Deliberately NOT declared a subproperty of prov:hadActivity: that property is used on reified influence/generation/usage objects, not on entities — an AuditEvidence is a prov:Entity that is ABOUT an activity, which PROV-O does not provide a direct property for."@en ;
    rdfs:domain daimo:AuditEvidence ;
    rdfs:range prov:Activity .

daimo:offersModel a owl:AsymmetricProperty,
        owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "offers model"@en ;
    rdfs:comment "Links a catalog-record offering to the AI model it registers. Functional: one offering registers exactly one model. Asymmetric: an offering is distinct from the model it offers."@en ;
    rdfs:domain daimo:AIAssetOffering ;
    rdfs:range it6:MachineLearningModel ;
    rdfs:subPropertyOf foaf:primaryTopic .

<https://w3id.org/pionera/daimo/align> a owl:Ontology ;
    rdfs:comment "Alignment axioms linking DAIMO classes and properties to DCAT, MLDCAT-AP, ODRL, PROV-O, and the Dataspace Protocol (DSP)."@en ;
    owl:imports <https://w3id.org/pionera/daimo> ;
    owl:versionIRI <https://w3id.org/pionera/daimo/align/0.1.6> ;
    owl:versionInfo "0.1.6" .

it6:Flow a owl:Class ;
    rdfs:label "Flow"@en ;
    rdfs:comment "MLDCAT-AP: a reproducible pipeline description (software, dependencies, structure) for building or executing a model."@en ;
    rdfs:isDefinedBy it6: ;
    rdfs:seeAlso <https://semiceu.github.io/MLDCAT-AP/releases/3.0.0/#Flow> .

dcat:Dataset a owl:Class ;
    rdfs:label "Dataset"@en ;
    rdfs:comment "DCAT: a collection of data, published or curated by a single source, available for access or download."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/dcat> ;
    rdfs:seeAlso <https://www.w3.org/TR/vocab-dcat-2/#Class:Dataset> .

odrl:Policy a owl:Class ;
    rdfs:label "Policy"@en ;
    rdfs:comment "ODRL: the common superclass of Offer, Agreement, Set, etc."@en ;
    rdfs:isDefinedBy odrl: .

it6:Task a owl:Class ;
    rdfs:label "Task"@en ;
    rdfs:comment "MLDCAT-AP: the problem definition over source data, linking datasets, features, estimation procedure, and evaluation measures."@en ;
    rdfs:isDefinedBy it6: ;
    rdfs:seeAlso <https://semiceu.github.io/MLDCAT-AP/releases/3.0.0/#Task> .

spdx:Checksum a owl:Class ;
    rdfs:label "Checksum"@en ;
    rdfs:comment "SPDX: the result of applying a cryptographic hash function over a file's content, bundling the algorithm (spdx:algorithm) and the hexadecimal digest (spdx:checksumValue)."@en ;
    rdfs:isDefinedBy spdx: ;
    rdfs:seeAlso <https://spdx.github.io/spdx-spec/v2.3/file-information/#84-file-checksum> .

dcat:Resource a owl:Class ;
    rdfs:label "Resource"@en ;
    rdfs:comment "DCAT: any resource published or curated by a single agent; the common supertype of Dataset, DataService, Distribution, and CatalogRecord."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/dcat> ;
    rdfs:seeAlso <https://www.w3.org/TR/vocab-dcat-2/#Class:Resource> .

daimo:CrossParticipantProvenanceRecord a owl:Class ;
    rdfs:label "cross-participant provenance record"@en ;
    rdfs:comment "A reusable semantic bundle that aggregates prov:Activity and prov:Entity across participant contexts to tell one audit-ready story."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf prov:Bundle ;
    skos:definition "A PROV bundle that aggregates activities and entities spanning at least two EDC participant contexts, forming an audit-ready cross-participant provenance narrative."@en ;
    skos:example "When a derived artefact is produced by a consumer invoking a provider's model hosted by a third-party operator, a CrossParticipantProvenanceRecord aggregates the relevant activities across the provider, consumer, and operator participant contexts into one bundle for audit."@en ;
    skos:related dspace:TransferProcess .

edc:ParticipantContext a owl:Class ;
    rdfs:label "Participant Context"@en ;
    rdfs:comment "EDC-specific extension: a multi-tenant runtime context identifying a participant within an EDC connector. Not yet standardised in DSP."@en ;
    rdfs:isDefinedBy edc: .

daimo:DerivedArtifact a owl:Class ;
    rdfs:label "derived artifact"@en ;
    rdfs:comment "A governed, catalog-describable output produced by an it6:Run in a dataspace context, bearing its own provenance and policy."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf dcat:Resource,
        prov:Entity ;
    skos:definition "A governed, catalog-describable output produced by a run in a dataspace context, carrying its own provenance pointer and authorisation pointer."@en ;
    skos:example "When a consumer invokes a deployed model, the run's output (a prediction dataset, a classification result, a generated artefact) is typed as a DerivedArtifact that points back to the producing run (daimo:derivedFromRun) and to the authorisation under which it was produced (daimo:underAuthorization)."@en .

it6:Run a owl:Class ;
    rdfs:label "Run"@en ;
    rdfs:comment "MLDCAT-AP: a concrete execution of an algorithm over data, producing outputs and evaluations. Specialises mls:Run."@en ;
    rdfs:isDefinedBy it6: ;
    rdfs:seeAlso <https://semiceu.github.io/MLDCAT-AP/releases/3.0.0/#Run> .

prov:Entity a owl:Class ;
    rdfs:label "Entity"@en ;
    rdfs:comment "PROV-O: a physical, digital, or conceptual thing with fixed aspects; entities may be real or imaginary."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
    rdfs:seeAlso <https://www.w3.org/TR/prov-o/#Entity> .

foaf:Agent a owl:Class ;
    rdfs:label "Agent"@en ;
    rdfs:comment "FOAF: a thing that does stuff; a person, group, organisation, or software entity."@en ;
    rdfs:isDefinedBy foaf: ;
    rdfs:seeAlso <http://xmlns.com/foaf/spec/#term_Agent> .

daimo:AIAssetOffering a owl:Class ;
    rdfs:label "AI asset offering"@en ;
    rdfs:comment "A catalog-record entry that registers an AI model in a dataspace catalog, bundling the model reference, the providing agent, and an ODRL offer policy. Specialises dcat:CatalogRecord; carries an odrl:Offer via daimo:hasOfferPolicy. In DSP terms this is the catalog-time artefact that becomes a dspace:ContractOffer during negotiation."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf dcat:CatalogRecord ;
    skos:definition "A catalog-record entry registering an AI model in a dataspace catalog as a governed offer, bundling the model, the issuing agent, and an ODRL offer policy."@en ;
    skos:example "A research organisation publishing one of its machine-learning models into a dataspace catalog declares an AIAssetOffering that references the model (via offersModel), the organisation itself (via offeredBy), and an ODRL offer policy (via hasOfferPolicy) permitting use and distribution under a specific licence."@en ;
    skos:related dspace:ContractOffer .

it6:MachineLearningModel a owl:Class ;
    rdfs:label "Machine Learning Model"@en ;
    rdfs:comment "MLDCAT-AP: a file or set of artefacts that has been trained to recognise patterns; the central ML asset class, itself a subclass of dcat:Dataset."@en ;
    rdfs:isDefinedBy it6: ;
    rdfs:seeAlso <https://semiceu.github.io/MLDCAT-AP/releases/3.0.0/#MachineLearningModel> .

daimo:AuditEvidence a owl:Class ;
    rdfs:label "audit evidence"@en ;
    rdfs:comment "A compliance-oriented evidence record attached to a governed event, carrying integrity hash, signer, and timestamp."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf prov:Entity ;
    skos:definition "A compliance-oriented evidence record attached to a governed activity, carrying a structured SPDX checksum (algorithm + digest), a signer, and a timestamp."@en ;
    skos:example "For each run of a deployed model, the PlatformOperator produces an AuditEvidence record that references the run (daimo:evidenceOf), carries a structured spdx:Checksum (algorithm + digest) over the run's outputs (daimo:integrityHash), identifies the signer (daimo:signedBy), and timestamps the sealing (daimo:recordedAt)."@en .

daimo:ExecutionAuthorization a owl:Class ;
    rdfs:label "execution authorization"@en ;
    rdfs:comment "An ODRL agreement (produced by a DSP contract negotiation) that binds at least one odrl:permission to concrete it6:Run invocations it authorises. Specialises odrl:Agreement; MUST carry at least one odrl:permission per the ODRL policy model."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf odrl:Agreement ;
    skos:definition "An ODRL agreement, produced by a Dataspace-Protocol contract negotiation, that binds specific ODRL permissions to concrete MLDCAT-AP run invocations it authorises, with an expiry timestamp and a grantee agent."@en ;
    skos:example "After a successful DSP contract negotiation, the resulting agreement is represented as an ExecutionAuthorization granting odrl:use to the consumer (daimo:grantedTo), covering one or more runs via daimo:authorizesRun, expiring at a specified daimo:expiresAt timestamp."@en ;
    skos:related dspace:ContractNegotiation .

daimo:ModelDeployment a owl:Class ;
    rdfs:label "model deployment"@en ;
    rdfs:comment "A running or hosted instance of an MLDCAT-AP MachineLearningModel exposed through a dcat:DataService under an operational environment."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf prov:Entity ;
    skos:definition "A running or hosted instance of a machine-learning model exposed through one or more DCAT data services over a named compute infrastructure, under a per-service I/O contract."@en ;
    skos:example "A PlatformOperator that stands up a live inference endpoint for a given model creates a ModelDeployment that (i) deploys the model, (ii) is exposed as one or more dcat:DataServices (e.g., REST + gRPC), (iii) runs on a specific it6:ComputerInfrastructure, and (iv) declares an IOContract per exposed service."@en ;
    skos:related it6:MachineLearningModel .

prov:Activity a owl:Class ;
    rdfs:label "Activity"@en ;
    rdfs:comment "PROV-O: something that occurs over a period of time and acts on or with entities."@en ;
    rdfs:isDefinedBy <http://www.w3.org/ns/prov-o#> ;
    rdfs:seeAlso <https://www.w3.org/TR/prov-o/#Activity> .

daimo:IOContract a owl:Class ;
    rdfs:label "I/O contract"@en ;
    rdfs:comment "The minimum machine-actionable invocation contract for a deployment: input format, output format, authentication method, and optional input/output schemas."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    skos:definition "The minimum machine-actionable invocation contract for a deployment endpoint: input media type, output media type, authentication method, and optional input/output schemas."@en ;
    skos:example "A REST inference endpoint might declare an IOContract with inputFormat \"application/json\", outputFormat \"application/geo+json\", and authMethod \"oauth2-bearer\"; a parallel gRPC endpoint on the same deployment can declare a second IOContract with inputFormat \"application/x-protobuf\" and authMethod \"mtls\"."@en .

daimo:ParticipantRole a owl:Class ;
    rdfs:label "participant role"@en ;
    rdfs:comment "A dataspace-scoped role taken by a participant with respect to AI assets. Anti-rigid: an agent can gain and lose roles over time. Subclasses are intentionally NOT mutually disjoint — one agent can hold several roles simultaneously (e.g., a research group may be both Evaluator and Model Provider)."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    rdfs:subClassOf prov:Role ;
    skos:definition "A dataspace-scoped role played by a participant with respect to AI assets (anti-rigid; an agent gains and loses roles over time)."@en ;
    skos:example "An agent acting as a Model Provider within a given EDC participant context has a ParticipantRole instance of type ModelProvider connected via daimo:hasRole and scoped by daimo:inParticipantContext."@en .

daimo:SharedEvaluationContext a owl:Class ;
    rdfs:label "shared evaluation context"@en ;
    rdfs:comment "A reified grouping of the conditions under which model results are comparable: task, dataset, dataset version, protocol, and random seed. Does not claim to cover every facet that affects comparability (metric, split strategy, hyperparameters); it is the minimum grouping required by CQ-V1..CQ-V3."@en ;
    rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
    skos:definition "A reified grouping of the conditions under which model evaluations are comparable: task, dataset, dataset version, evaluation protocol, and random seed."@en ;
    skos:example "Two candidate models evaluated on the same SharedEvaluationContext (identical it6:Task, dcat:Dataset, daimo:datasetVersion, daimo:protocol, and daimo:randomSeed) yield metric values that are directly comparable; changing any of the five facets breaks comparability."@en ;
    skos:related it6:EstimationProcedure,
        it6:Task .

<https://w3id.org/pionera/daimo> a owl:Ontology ;
    dct:conformsTo <https://www.w3.org/TR/owl2-overview/> ;
    dct:contributor <https://ror.org/03n6nwv02> ;
    dct:creator <https://orcid.org/0000-0000-0000-0000>,
        <https://orcid.org/0000-0000-0000-0001> ;
    dct:description "DAIMO is an integration profile that connects DCAT-AP, MLDCAT-AP, ODRL, PROV-O, and the Dataspace Protocol (DSP, as operationalised by Eclipse EDC) to support publication, discovery, invocation, execution traceability, and contextualised evaluation of AI model assets exchanged in data spaces. The edc: namespace is used only for EDC-specific extensions (e.g., ParticipantContext) not yet standardised in DSP."@en ;
    dct:issued "2026-04-22"^^xsd:date ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:modified "2026-07-06"^^xsd:date ;
    dct:publisher <https://w3id.org/pionera> ;
    dct:title "DAIMO: an ontology for governed AI model assets in data spaces"@en ;
    vann:preferredNamespacePrefix "daimo" ;
    vann:preferredNamespaceUri "https://w3id.org/pionera/daimo#" ;
    rdfs:comment "See the companion documents ONTOLOGY-REFERENCE.md (class-by-class reference), VALIDATION-MATRIX.md (traceability), and daimo-ontology-design.md (design rationale) in the source repository."@en ;
    rdfs:seeAlso <https://w3id.org/pionera/daimo/align>,
        <https://w3id.org/pionera/daimo/docs>,
        <https://w3id.org/pionera/daimo/shapes> ;
    owl:priorVersion <https://w3id.org/pionera/daimo/0.1.5> ;
    owl:versionIRI <https://w3id.org/pionera/daimo/0.1.6> ;
    owl:versionInfo "0.1.6" .

