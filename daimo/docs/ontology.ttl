#################################################################

###  http://purl.org/dc/terms/conformsTo
<http://purl.org/dc/terms/conformsTo> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
<http://purl.org/dc/terms/issued> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
<http://www.w3.org/2004/02/skos/core#definition> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
<http://www.w3.org/2004/02/skos/core#example> rdf:type owl:AnnotationProperty .


###  http://xmlns.com/foaf/0.1/name
<http://xmlns.com/foaf/0.1/name> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://data.europa.eu/it6/hasTask
<http://data.europa.eu/it6/hasTask> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/odrl/2/assignee
<http://www.w3.org/ns/odrl/2/assignee> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/odrl/2/hasPolicy
<http://www.w3.org/ns/odrl/2/hasPolicy> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasGeneratedBy
<http://www.w3.org/ns/prov#wasGeneratedBy> rdf:type owl:ObjectProperty .


###  http://xmlns.com/foaf/0.1/isPrimaryTopicOf
<http://xmlns.com/foaf/0.1/isPrimaryTopicOf> rdf:type owl:ObjectProperty .


###  http://xmlns.com/foaf/0.1/primaryTopic
<http://xmlns.com/foaf/0.1/primaryTopic> rdf:type owl:ObjectProperty .


###  https://w3id.org/pionera/daimo#authorizedBy
:authorizedBy rdf:type owl:ObjectProperty ;
              owl:inverseOf :authorizesRun ;
              rdf:type owl:FunctionalProperty ;
              rdfs:domain <http://data.europa.eu/it6/Run> ;
              rdfs:range :ExecutionAuthorization ;
              rdfs:comment "Inverse of daimo:authorizesRun. Functional: each run is authorized by exactly one agreement."@en ;
              rdfs:label "authorized by"@en .


###  https://w3id.org/pionera/daimo#authorizesRun
:authorizesRun rdf:type owl:ObjectProperty ,
                        owl:AsymmetricProperty ;
               rdfs:domain :ExecutionAuthorization ;
               rdfs:range <http://data.europa.eu/it6/Run> ;
               rdfs:comment "Links an authorization to a run it permits. Non-functional: a single authorization can cover multiple runs (e.g., subscription-style access). Asymmetric: an authorization is distinct from any run it authorises. Deliberately NOT declared a subproperty of prov:used: an odrl:Agreement is a policy artefact (an Entity), not a prov:Activity; the prov:used domain would incorrectly force ExecutionAuthorization ⊑ prov:Activity."@en ;
               rdfs:label "authorizes run"@en .


###  https://w3id.org/pionera/daimo#contextDataset
:contextDataset rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :SharedEvaluationContext ;
                rdfs:range <http://www.w3.org/ns/dcat#Dataset> ;
                rdfs:comment "The dcat:Dataset the evaluation context is defined over. Functional. Not declared a subproperty of it6:trainedOn because an evaluation-context dataset is an evaluation dataset, not necessarily a training dataset."@en ;
                rdfs:label "context dataset"@en .


###  https://w3id.org/pionera/daimo#contextFlow
:contextFlow rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :SharedEvaluationContext ;
             rdfs:range <http://data.europa.eu/it6/Flow> ;
             rdfs:comment "The it6:Flow (pipeline / reproducibility artefact) referenced by the evaluation context. Functional. Not declared a subproperty of it6:hasFlow because the evaluation context is not itself a run."@en ;
             rdfs:label "context flow"@en .


###  https://w3id.org/pionera/daimo#contextTask
:contextTask rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf <http://data.europa.eu/it6/hasTask> ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :SharedEvaluationContext ;
             rdfs:range <http://data.europa.eu/it6/Task> ;
             rdfs:comment "The it6:Task the evaluation context is defined over. Functional."@en ;
             rdfs:label "context task"@en .


###  https://w3id.org/pionera/daimo#deploysModel
:deploysModel rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ,
                       owl:AsymmetricProperty ;
              rdfs:domain :ModelDeployment ;
              rdfs:range <http://data.europa.eu/it6/MachineLearningModel> ;
              rdfs:comment "Links a deployment to the model it serves. Functional: one deployment serves one model. Asymmetric: a deployment and its model are distinct individuals."@en ;
              rdfs:label "deploys model"@en .


###  https://w3id.org/pionera/daimo#derivedFromRun
:derivedFromRun rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasGeneratedBy> ;
                rdf:type owl:FunctionalProperty ,
                         owl:AsymmetricProperty ;
                rdfs:domain :DerivedArtifact ;
                rdfs:range <http://data.europa.eu/it6/Run> ;
                rdfs:comment "Links a derived artifact to the run that produced it. Functional: each derived artifact has exactly one originating run. Asymmetric: an artifact and its generating run are distinct."@en ;
                rdfs:label "derived from run"@en .


###  https://w3id.org/pionera/daimo#evidenceOf
:evidenceOf rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ,
                     owl:AsymmetricProperty ;
            rdfs:domain :AuditEvidence ;
            rdfs:range <http://www.w3.org/ns/prov#Activity> ;
            rdfs:comment "Links audit evidence to the activity it attests. Functional. Asymmetric: audit evidence is distinct from the activity it records. Deliberately NOT declared a subproperty of prov:hadActivity: that property is used on reified influence/generation/usage objects, not on entities — an AuditEvidence is a prov:Entity that is ABOUT an activity, which PROV-O does not provide a direct property for."@en ;
            rdfs:label "evidence of"@en .


###  https://w3id.org/pionera/daimo#exposedAs
:exposedAs rdf:type owl:ObjectProperty ;
           rdfs:domain :ModelDeployment ;
           rdfs:range <http://www.w3.org/ns/dcat#DataService> ;
           rdfs:comment "Links a deployment to the DCAT data service(s) that expose it. Non-functional: one deployment may expose multiple endpoints (e.g., a REST service plus a gRPC service, or regional load-balanced endpoints). Each service's I/O contract can differ (see daimo:hasIOContract, also non-functional)."@en ;
           rdfs:label "exposed as"@en .


###  https://w3id.org/pionera/daimo#grantedTo
:grantedTo rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf <http://www.w3.org/ns/odrl/2/assignee> ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :ExecutionAuthorization ;
           rdfs:range <http://xmlns.com/foaf/0.1/Agent> ;
           rdfs:comment "Links an authorization to the grantee agent. Functional. Specialises odrl:assignee (the ODRL party receiving an agreement's terms). Deliberately NOT aligned to prov:qualifiedAssociation: that property points to a reified prov:Association object, not to the agent itself; using it here would incorrectly type every grantee Agent as a prov:Association."@en ;
           rdfs:label "granted to"@en .


###  https://w3id.org/pionera/daimo#hasAuditEvidence
:hasAuditEvidence rdf:type owl:ObjectProperty ;
                  owl:inverseOf :evidenceOf ;
                  rdfs:domain <http://www.w3.org/ns/prov#Activity> ;
                  rdfs:range :AuditEvidence ;
                  rdfs:comment "Inverse of daimo:evidenceOf: from an activity, retrieve every audit-evidence record attesting it. Non-functional (multiple auditors can independently attest the same activity)."@en ;
                  rdfs:label "has audit evidence"@en .


###  https://w3id.org/pionera/daimo#hasDeployment
:hasDeployment rdf:type owl:ObjectProperty ;
               owl:inverseOf :deploysModel ;
               rdfs:domain <http://data.europa.eu/it6/MachineLearningModel> ;
               rdfs:range :ModelDeployment ;
               rdfs:comment "Inverse of daimo:deploysModel: from a model, retrieve every deployment that serves it. Non-functional (a model can have multiple deployments across contexts)."@en ;
               rdfs:label "has deployment"@en .


###  https://w3id.org/pionera/daimo#hasDerivedArtifact
:hasDerivedArtifact rdf:type owl:ObjectProperty ;
                    owl:inverseOf :derivedFromRun ;
                    rdfs:domain <http://data.europa.eu/it6/Run> ;
                    rdfs:range :DerivedArtifact ;
                    rdfs:comment "Inverse of daimo:derivedFromRun: from a run, retrieve every derived artifact it produced. Non-functional (a run may produce multiple governed outputs)."@en ;
                    rdfs:label "has derived artifact"@en .


###  https://w3id.org/pionera/daimo#hasIOContract
:hasIOContract rdf:type owl:ObjectProperty ;
               rdfs:domain :ModelDeployment ;
               rdfs:range :IOContract ;
               rdfs:comment "Links a deployment to its invocation contract(s). Non-functional: a deployment exposing multiple services (see daimo:exposedAs) may carry a distinct IOContract per protocol (e.g., JSON+OAuth2 for REST and protobuf+mTLS for gRPC)."@en ;
               rdfs:label "has I/O contract"@en .


###  https://w3id.org/pionera/daimo#hasOfferPolicy
:hasOfferPolicy rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf <http://www.w3.org/ns/odrl/2/hasPolicy> ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain :AIAssetOffering ;
                rdfs:range <http://www.w3.org/ns/odrl/2/Offer> ;
                rdfs:comment "Links an offering to the ODRL offer policy that governs the offered model. Functional: each offering carries exactly one canonical offer policy."@en ;
                rdfs:label "has offer policy"@en .


###  https://w3id.org/pionera/daimo#hasOffering
:hasOffering rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/isPrimaryTopicOf> ;
             owl:inverseOf :offersModel ;
             rdfs:domain <http://data.europa.eu/it6/MachineLearningModel> ;
             rdfs:range :AIAssetOffering ;
             rdfs:comment "Inverse of daimo:offersModel: from a model, retrieve every catalog offering that registers it. Non-functional (the same model may be offered by different providers in different catalogs). Declared rdfs:subPropertyOf foaf:isPrimaryTopicOf for symmetry with daimo:offersModel ⊑ foaf:primaryTopic."@en ;
             rdfs:label "has offering"@en .


###  https://w3id.org/pionera/daimo#hasRole
:hasRole rdf:type owl:ObjectProperty ;
         rdfs:domain <http://xmlns.com/foaf/0.1/Agent> ;
         rdfs:range :ParticipantRole ;
         rdfs:comment "Links an agent to a dataspace role. Non-functional: agents may hold multiple roles."@en ;
         rdfs:label "has role"@en .


###  https://w3id.org/pionera/daimo#inParticipantContext
:inParticipantContext rdf:type owl:ObjectProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain :ParticipantRole ;
                      rdfs:range <https://w3id.org/edc/v0.0.1/ns/ParticipantContext> ;
                      rdfs:comment "Scopes a role assignment to a specific EDC participant context. Functional: a role instance is held within exactly one context."@en ;
                      rdfs:label "in participant context"@en .


###  https://w3id.org/pionera/daimo#inputSchema
:inputSchema rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :IOContract ;
             rdfs:range <http://www.w3.org/ns/dcat#Resource> ;
             rdfs:comment "Optional link to a resource describing the input payload schema (JSON Schema, SHACL shape, etc.)."@en ;
             rdfs:label "input schema"@en .


###  https://w3id.org/pionera/daimo#integrityHash
:integrityHash rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :AuditEvidence ;
               rdfs:range <http://spdx.org/rdf/terms#Checksum> ;
               rdfs:comment "Links audit evidence to an spdx:Checksum that bundles the algorithm (spdx:algorithm) and the digest value (spdx:checksumValue). Functional: exactly one canonical checksum per evidence record. A plain-string digest without its algorithm cannot be verified, so a structured spdx:Checksum is required rather than an xsd:string."@en ;
               rdfs:label "integrity hash"@en .


###  https://w3id.org/pionera/daimo#offeredBy
:offeredBy rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :AIAssetOffering ;
           rdfs:range <http://xmlns.com/foaf/0.1/Agent> ;
           rdfs:comment "Links an offering to the agent that authored the offered AI model (i.e., the model provider). Functional: each offering has exactly one offering agent. Deliberately NOT declared rdfs:subPropertyOf dct:publisher: on a dcat:CatalogRecord, dct:publisher denotes the catalog maintainer (the platform registering the record), not the author of the asset being registered. Conflating them would entail that the catalog-time publisher is the model creator — semantically wrong in a real dataspace where e.g. INESData publishes records authored by UPM."@en ;
           rdfs:label "offered by"@en .


###  https://w3id.org/pionera/daimo#offersModel
:offersModel rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/primaryTopic> ;
             rdf:type owl:FunctionalProperty ,
                      owl:AsymmetricProperty ;
             rdfs:domain :AIAssetOffering ;
             rdfs:range <http://data.europa.eu/it6/MachineLearningModel> ;
             rdfs:comment "Links a catalog-record offering to the AI model it registers. Functional: one offering registers exactly one model. Asymmetric: an offering is distinct from the model it offers."@en ;
             rdfs:label "offers model"@en .


###  https://w3id.org/pionera/daimo#onInfrastructure
:onInfrastructure rdf:type owl:ObjectProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :ModelDeployment ;
                  rdfs:range <http://data.europa.eu/it6/ComputerInfrastructure> ;
                  rdfs:comment "Links a deployment to the MLDCAT-AP computer infrastructure running it. Functional: one deployment runs on one canonical infrastructure instance (redundancy is modelled as multiple deployments)."@en ;
                  rdfs:label "on infrastructure"@en .


###  https://w3id.org/pionera/daimo#outputSchema
:outputSchema rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :IOContract ;
              rdfs:range <http://www.w3.org/ns/dcat#Resource> ;
              rdfs:comment "Optional link to a resource describing the output payload schema."@en ;
              rdfs:label "output schema"@en .


###  https://w3id.org/pionera/daimo#records
:records rdf:type owl:ObjectProperty ;
         rdfs:domain :CrossParticipantProvenanceRecord ;
         rdfs:range <http://www.w3.org/ns/prov#Activity> ;
         rdfs:comment "Links a cross-participant provenance bundle to each prov:Activity that forms part of the audit-ready narrative."@en ;
         rdfs:label "records"@en .


###  https://w3id.org/pionera/daimo#signedBy
:signedBy rdf:type owl:ObjectProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :AuditEvidence ;
          rdfs:range <http://xmlns.com/foaf/0.1/Agent> ;
          rdfs:comment "Functional: one signer per evidence record."@en ;
          rdfs:label "signed by"@en .


###  https://w3id.org/pionera/daimo#spansParticipantContext
:spansParticipantContext rdf:type owl:ObjectProperty ;
                         rdfs:domain :CrossParticipantProvenanceRecord ;
                         rdfs:range <https://w3id.org/edc/v0.0.1/ns/ParticipantContext> ;
                         rdfs:comment "Links a cross-participant provenance bundle to each participant context whose activities or entities it records. A record must span at least two contexts (enforced by SHACL)."@en ;
                         rdfs:label "spans participant context"@en .


###  https://w3id.org/pionera/daimo#underAuthorization
:underAuthorization rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :DerivedArtifact ;
                    rdfs:range :ExecutionAuthorization ;
                    rdfs:comment "Links a derived artifact to the authorisation under which it was produced. Functional."@en ;
                    rdfs:label "under authorization"@en .


###  https://w3id.org/pionera/daimo#usesEvaluationContext
:usesEvaluationContext rdf:type owl:ObjectProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain <http://data.europa.eu/it6/Evaluation> ;
                       rdfs:range :SharedEvaluationContext ;
                       rdfs:comment "Links an it6:Evaluation to the shared evaluation context under which its results are comparable to other evaluations. Functional."@en ;
                       rdfs:label "uses evaluation context"@en .


#################################################################
#    Data properties
#################################################################

###  https://w3id.org/pionera/daimo#authMethod
:authMethod rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :IOContract ;
            rdfs:range xsd:string ;
            rdfs:comment "Authentication-method token (e.g. \"oauth2-bearer\", \"api-key\", \"mtls\")."@en ;
            rdfs:label "authentication method"@en .


###  https://w3id.org/pionera/daimo#datasetVersion
:datasetVersion rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :SharedEvaluationContext ;
                rdfs:range xsd:string ;
                rdfs:comment "Literal version identifier of the evaluation dataset used by the context. Deliberately not aligned to dct:hasVersion because dct:hasVersion relates a resource to another version resource, whereas DAIMO records the dataset-version token as a literal for reproducible benchmarking."@en ;
                rdfs:label "dataset version"@en .


###  https://w3id.org/pionera/daimo#expiresAt
:expiresAt rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :ExecutionAuthorization ;
           rdfs:range xsd:dateTime ;
           rdfs:comment "Expiry timestamp of the execution authorisation."@en ;
           rdfs:label "expires at"@en .


###  https://w3id.org/pionera/daimo#inputFormat
:inputFormat rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :IOContract ;
             rdfs:range xsd:string ;
             rdfs:comment "IANA media type of the expected input payload (e.g. \"application/json\")."@en ;
             rdfs:label "input format"@en .


###  https://w3id.org/pionera/daimo#outputFormat
:outputFormat rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :IOContract ;
              rdfs:range xsd:string ;
              rdfs:comment "IANA media type of the produced output payload (e.g. \"application/geo+json\")."@en ;
              rdfs:label "output format"@en .


###  https://w3id.org/pionera/daimo#protocol
:protocol rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :SharedEvaluationContext ;
          rdfs:range xsd:string ;
          rdfs:comment "Name of the evaluation protocol (e.g. \"holdout\", \"5-fold-cv\", \"bootstrap-1000\")."@en ;
          rdfs:label "evaluation protocol"@en .


###  https://w3id.org/pionera/daimo#randomSeed
:randomSeed rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :SharedEvaluationContext ;
            rdfs:range xsd:integer ;
            rdfs:comment "Random seed fixing stochastic components of the protocol, required for reproducibility."@en ;
            rdfs:label "random seed"@en .


###  https://w3id.org/pionera/daimo#recordedAt
:recordedAt rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :AuditEvidence ;
            rdfs:range xsd:dateTime ;
            rdfs:comment "Timestamp at which the audit evidence was sealed."@en ;
            rdfs:label "recorded at"@en .


#################################################################
#    Classes
#################################################################

###  http://data.europa.eu/it6/ComputerInfrastructure
<http://data.europa.eu/it6/ComputerInfrastructure> rdf:type owl:Class .


###  http://data.europa.eu/it6/Evaluation
<http://data.europa.eu/it6/Evaluation> rdf:type owl:Class .


###  http://data.europa.eu/it6/Flow
<http://data.europa.eu/it6/Flow> rdf:type owl:Class .


###  http://data.europa.eu/it6/MachineLearningModel
<http://data.europa.eu/it6/MachineLearningModel> rdf:type owl:Class .


###  http://data.europa.eu/it6/Run
<http://data.europa.eu/it6/Run> rdf:type owl:Class .


###  http://data.europa.eu/it6/Task
<http://data.europa.eu/it6/Task> rdf:type owl:Class .


###  http://spdx.org/rdf/terms#Checksum
<http://spdx.org/rdf/terms#Checksum> rdf:type owl:Class .


###  http://www.w3.org/ns/dcat#CatalogRecord
<http://www.w3.org/ns/dcat#CatalogRecord> rdf:type owl:Class .


###  http://www.w3.org/ns/dcat#DataService
<http://www.w3.org/ns/dcat#DataService> rdf:type owl:Class .


