@prefix : <https://w3id.org/pionera/daimo#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/pionera/daimo#> .

<https://w3id.org/pionera/daimo> rdf:type owl:Ontology ;
                                  owl:versionIRI <https://w3id.org/pionera/daimo/0.1.1> ;
                                  <http://purl.org/dc/terms/description> "DAIMO is an integration profile that connects DCAT-AP, MLDCAT-AP, ODRL, PROV-O, and the Dataspace Protocol (DSP, as operationalised by Eclipse EDC) to support publication, discovery, invocation, execution traceability, and contextualised evaluation of AI model assets exchanged in data spaces. The edc: namespace is used only for EDC-specific extensions (e.g., ParticipantContext) not yet standardised in DSP."@en ;
                                  <http://purl.org/dc/terms/issued> "2026-04-22"^^xsd:date ;
                                  <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                  <http://purl.org/dc/terms/modified> "2026-04-22"^^xsd:date ;
                                  <http://purl.org/dc/terms/title> "DAIMO: an ontology for governed AI model assets in data spaces"@en ;
                                  <http://purl.org/vocab/vann/preferredNamespacePrefix> "daimo" ;
                                  <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/pionera/daimo#" ;
                                  rdfs:comment "See daimo-ontology-design.md for the full design rationale."@en ;
                                  owl:versionInfo "0.1.1" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
<http://purl.org/dc/terms/issued> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
<http://purl.org/dc/terms/modified> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://data.europa.eu/it6/hasFlow
<http://data.europa.eu/it6/hasFlow> rdf:type owl:ObjectProperty .


###  http://data.europa.eu/it6/hasTask
<http://data.europa.eu/it6/hasTask> rdf:type owl:ObjectProperty .


###  http://data.europa.eu/it6/trainedOn
<http://data.europa.eu/it6/trainedOn> rdf:type owl:ObjectProperty .


###  http://purl.org/dc/terms/publisher
<http://purl.org/dc/terms/publisher> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/odrl/2/assignee
<http://www.w3.org/ns/odrl/2/assignee> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/odrl/2/hasPolicy
<http://www.w3.org/ns/odrl/2/hasPolicy> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#hadActivity
<http://www.w3.org/ns/prov#hadActivity> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#used
<http://www.w3.org/ns/prov#used> rdf:type owl:ObjectProperty .


###  http://www.w3.org/ns/prov#wasGeneratedBy
<http://www.w3.org/ns/prov#wasGeneratedBy> rdf:type owl:ObjectProperty .


###  http://xmlns.com/foaf/0.1/primaryTopic
<http://xmlns.com/foaf/0.1/primaryTopic> rdf:type owl:ObjectProperty .


###  https://w3id.org/pionera/daimo#authorizedBy
:authorizedBy rdf:type owl:ObjectProperty ;
              owl:inverseOf :authorizesRun ;
              rdf:type owl:FunctionalProperty ;
              rdfs:domain <http://data.europa.eu/it6/Run> ;
              rdfs:range :ExecutionAuthorization ;
              rdfs:comment "Inverse of daimo:authorizesRun. Functional: each run is authorized by exactly one agreement."@en ;
              rdfs:label "authorized by"@en .


###  https://w3id.org/pionera/daimo#authorizesRun
:authorizesRun rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf <http://www.w3.org/ns/prov#used> ;
               rdfs:domain :ExecutionAuthorization ;
               rdfs:range <http://data.europa.eu/it6/Run> ;
               rdfs:comment "Links an authorization to a run it permits. Non-functional: a single authorization can cover multiple runs (e.g., subscription-style access)."@en ;
               rdfs:label "authorizes run"@en .


###  https://w3id.org/pionera/daimo#contextDataset
:contextDataset rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf <http://data.europa.eu/it6/trainedOn> ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain :SharedEvaluationContext ;
                rdfs:range <http://www.w3.org/ns/dcat#Dataset> ;
                rdfs:label "context dataset"@en .


###  https://w3id.org/pionera/daimo#contextFlow
:contextFlow rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf <http://data.europa.eu/it6/hasFlow> ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :SharedEvaluationContext ;
             rdfs:range <http://data.europa.eu/it6/Flow> ;
             rdfs:label "context flow"@en .


###  https://w3id.org/pionera/daimo#contextTask
:contextTask rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf <http://data.europa.eu/it6/hasTask> ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :SharedEvaluationContext ;
             rdfs:range <http://data.europa.eu/it6/Task> ;
             rdfs:label "context task"@en .


###  https://w3id.org/pionera/daimo#deploysModel
:deploysModel rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :ModelDeployment ;
              rdfs:range <http://data.europa.eu/it6/MachineLearningModel> ;
              rdfs:comment "Links a deployment to the model it serves. Functional: one deployment serves one model."@en ;
              rdfs:label "deploys model"@en .


###  https://w3id.org/pionera/daimo#derivedFromRun
:derivedFromRun rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf <http://www.w3.org/ns/prov#wasGeneratedBy> ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain :DerivedArtifact ;
                rdfs:range <http://data.europa.eu/it6/Run> ;
                rdfs:comment "Links a derived artifact to the run that produced it. Functional: each derived artifact has exactly one originating run."@en ;
                rdfs:label "derived from run"@en .


###  https://w3id.org/pionera/daimo#evidenceOf
:evidenceOf rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf <http://www.w3.org/ns/prov#hadActivity> ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :AuditEvidence ;
            rdfs:range <http://www.w3.org/ns/prov#Activity> ;
            rdfs:comment "Links audit evidence to the activity it attests. Functional."@en ;
            rdfs:label "evidence of"@en .


###  https://w3id.org/pionera/daimo#exposedAs
:exposedAs rdf:type owl:ObjectProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :ModelDeployment ;
           rdfs:range <http://www.w3.org/ns/dcat#DataService> ;
           rdfs:comment "Links a deployment to the DCAT data service that exposes it. Functional."@en ;
           rdfs:label "exposed as"@en .


###  https://w3id.org/pionera/daimo#grantedTo
:grantedTo rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf <http://www.w3.org/ns/odrl/2/assignee> ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :ExecutionAuthorization ;
           rdfs:range <http://xmlns.com/foaf/0.1/Agent> ;
           rdfs:comment "Links an authorization to the grantee agent. Functional."@en ;
           rdfs:label "granted to"@en .


###  https://w3id.org/pionera/daimo#hasIOContract
:hasIOContract rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :ModelDeployment ;
               rdfs:range :IOContract ;
               rdfs:comment "Links a deployment to its invocation contract. Functional: one deployment has exactly one canonical I/O contract."@en ;
               rdfs:label "has I/O contract"@en .


###  https://w3id.org/pionera/daimo#hasOfferPolicy
:hasOfferPolicy rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf <http://www.w3.org/ns/odrl/2/hasPolicy> ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain :AIAssetOffering ;
                rdfs:range <http://www.w3.org/ns/odrl/2/Offer> ;
                rdfs:comment "Links an offering to the ODRL offer policy that governs the offered model. Functional: each offering carries exactly one canonical offer policy."@en ;
                rdfs:label "has offer policy"@en .


###  https://w3id.org/pionera/daimo#hasRole
:hasRole rdf:type owl:ObjectProperty ;
         rdfs:domain <http://xmlns.com/foaf/0.1/Agent> ;
         rdfs:range :ParticipantRole ;
         rdfs:comment "Links an agent to a dataspace role. Non-functional: agents may hold multiple roles."@en ;
         rdfs:label "has role"@en .


###  https://w3id.org/pionera/daimo#inParticipantContext
:inParticipantContext rdf:type owl:ObjectProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain :ParticipantRole ;
                      rdfs:range <https://w3id.org/edc/v0.0.1/ns/ParticipantContext> ;
                      rdfs:label "in participant context"@en .


###  https://w3id.org/pionera/daimo#inputSchema
:inputSchema rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :IOContract ;
             rdfs:range <http://www.w3.org/ns/dcat#Resource> ;
             rdfs:label "input schema"@en .


###  https://w3id.org/pionera/daimo#offeredBy
:offeredBy rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf <http://purl.org/dc/terms/publisher> ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :AIAssetOffering ;
           rdfs:range <http://xmlns.com/foaf/0.1/Agent> ;
           rdfs:comment "Links an offering to its publishing agent. Functional: each offering has exactly one provider."@en ;
           rdfs:label "offered by"@en .


###  https://w3id.org/pionera/daimo#offersModel
:offersModel rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf <http://xmlns.com/foaf/0.1/primaryTopic> ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :AIAssetOffering ;
             rdfs:range <http://data.europa.eu/it6/MachineLearningModel> ;
             rdfs:comment "Links a catalog-record offering to the AI model it registers. Functional: one offering registers exactly one model."@en ;
             rdfs:label "offers model"@en .


###  https://w3id.org/pionera/daimo#onInfrastructure
:onInfrastructure rdf:type owl:ObjectProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :ModelDeployment ;
                  rdfs:range <http://data.europa.eu/it6/ComputerInfrastructure> ;
                  rdfs:comment "Links a deployment to the MLDCAT-AP computer infrastructure running it. Functional: one deployment runs on one canonical infrastructure instance (redundancy is modelled as multiple deployments)."@en ;
                  rdfs:label "on infrastructure"@en .


###  https://w3id.org/pionera/daimo#outputSchema
:outputSchema rdf:type owl:ObjectProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :IOContract ;
              rdfs:range <http://www.w3.org/ns/dcat#Resource> ;
              rdfs:label "output schema"@en .


###  https://w3id.org/pionera/daimo#records
:records rdf:type owl:ObjectProperty ;
         rdfs:domain :CrossParticipantProvenanceRecord ;
         rdfs:range <http://www.w3.org/ns/prov#Activity> ;
         rdfs:label "records"@en .


###  https://w3id.org/pionera/daimo#signedBy
:signedBy rdf:type owl:ObjectProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :AuditEvidence ;
          rdfs:range <http://xmlns.com/foaf/0.1/Agent> ;
          rdfs:comment "Functional: one signer per evidence record."@en ;
          rdfs:label "signed by"@en .


###  https://w3id.org/pionera/daimo#spansParticipantContext
:spansParticipantContext rdf:type owl:ObjectProperty ;
                         rdfs:domain :CrossParticipantProvenanceRecord ;
                         rdfs:range <https://w3id.org/edc/v0.0.1/ns/ParticipantContext> ;
                         rdfs:label "spans participant context"@en .


###  https://w3id.org/pionera/daimo#underAuthorization
:underAuthorization rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :DerivedArtifact ;
                    rdfs:range :ExecutionAuthorization ;
                    rdfs:comment "Links a derived artifact to the authorisation under which it was produced. Functional."@en ;
                    rdfs:label "under authorization"@en .


###  https://w3id.org/pionera/daimo#usesEvaluationContext
:usesEvaluationContext rdf:type owl:ObjectProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain <http://data.europa.eu/it6/Evaluation> ;
                       rdfs:range :SharedEvaluationContext ;
                       rdfs:label "uses evaluation context"@en .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/hasVersion
<http://purl.org/dc/terms/hasVersion> rdf:type owl:DatatypeProperty .


###  https://w3id.org/pionera/daimo#authMethod
:authMethod rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :IOContract ;
            rdfs:range xsd:string ;
            rdfs:label "authentication method"@en .


###  https://w3id.org/pionera/daimo#datasetVersion
:datasetVersion rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf <http://purl.org/dc/terms/hasVersion> ;
                rdf:type owl:FunctionalProperty ;
                rdfs:domain :SharedEvaluationContext ;
                rdfs:range xsd:string ;
                rdfs:label "dataset version"@en .


###  https://w3id.org/pionera/daimo#expiresAt
:expiresAt rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :ExecutionAuthorization ;
           rdfs:range xsd:dateTime ;
           rdfs:label "expires at"@en .


###  https://w3id.org/pionera/daimo#inputFormat
:inputFormat rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :IOContract ;
             rdfs:range xsd:string ;
             rdfs:label "input format"@en .


###  https://w3id.org/pionera/daimo#integrityHash
:integrityHash rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :AuditEvidence ;
               rdfs:range xsd:string ;
               rdfs:label "integrity hash"@en .


###  https://w3id.org/pionera/daimo#outputFormat
:outputFormat rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :IOContract ;
              rdfs:range xsd:string ;
              rdfs:label "output format"@en .


###  https://w3id.org/pionera/daimo#protocol
:protocol rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :SharedEvaluationContext ;
          rdfs:range xsd:string ;
          rdfs:label "evaluation protocol"@en .


###  https://w3id.org/pionera/daimo#randomSeed
:randomSeed rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :SharedEvaluationContext ;
            rdfs:range xsd:integer ;
            rdfs:label "random seed"@en .


###  https://w3id.org/pionera/daimo#recordedAt
:recordedAt rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :AuditEvidence ;
            rdfs:range xsd:dateTime ;
            rdfs:label "recorded at"@en .


#################################################################
#    Classes
#################################################################

###  http://data.europa.eu/it6/ComputerInfrastructure
<http://data.europa.eu/it6/ComputerInfrastructure> rdf:type owl:Class .


###  http://data.europa.eu/it6/Evaluation
<http://data.europa.eu/it6/Evaluation> rdf:type owl:Class .


###  http://data.europa.eu/it6/Flow
<http://data.europa.eu/it6/Flow> rdf:type owl:Class .


###  http://data.europa.eu/it6/MachineLearningModel
<http://data.europa.eu/it6/MachineLearningModel> rdf:type owl:Class .


###  http://data.europa.eu/it6/Run
<http://data.europa.eu/it6/Run> rdf:type owl:Class .


###  http://data.europa.eu/it6/Task
<http://data.europa.eu/it6/Task> rdf:type owl:Class .


###  http://www.w3.org/ns/dcat#CatalogRecord
<http://www.w3.org/ns/dcat#CatalogRecord> rdf:type owl:Class .


###  http://www.w3.org/ns/dcat#DataService
<http://www.w3.org/ns/dcat#DataService> rdf:type owl:Class .


###  http://www.w3.org/ns/dcat#Dataset
<http://www.w3.org/ns/dcat#Dataset> rdf:type owl:Class .


###  http://www.w3.org/ns/dcat#Resource
<http://www.w3.org/ns/dcat#Resource> rdf:type owl:Class .


###  http://www.w3.org/ns/odrl/2/Agreement
<http://www.w3.org/ns/odrl/2/Agreement> rdf:type owl:Class .


###  http://www.w3.org/ns/odrl/2/Offer
<http://www.w3.org/ns/odrl/2/Offer> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Activity
<http://www.w3.org/ns/prov#Activity> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Bundle
<http://www.w3.org/ns/prov#Bundle> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
<http://www.w3.org/ns/prov#Entity> rdf:type owl:Class .


###  http://xmlns.com/foaf/0.1/Agent
<http://xmlns.com/foaf/0.1/Agent> rdf:type owl:Class .


###  https://w3id.org/edc/v0.0.1/ns/ParticipantContext
<https://w3id.org/edc/v0.0.1/ns/ParticipantContext> rdf:type owl:Class .


###  https://w3id.org/pionera/daimo#AIAssetOffering
:AIAssetOffering rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/dcat#CatalogRecord> ;
                 rdfs:comment "A catalog-record entry that registers an AI model in a dataspace catalog, bundling the model reference, the providing agent, and an ODRL offer policy. Specialises dcat:CatalogRecord; carries an odrl:Offer via daimo:hasOfferPolicy. In DSP terms this is the catalog-time artefact that becomes a dspace:ContractOffer during negotiation."@en ;
                 rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                 rdfs:label "AI asset offering"@en .


###  https://w3id.org/pionera/daimo#AuditEvidence
:AuditEvidence rdf:type owl:Class ;
               rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
               rdfs:comment "A compliance-oriented evidence record attached to a governed event, carrying integrity hash, signer, and timestamp."@en ;
               rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
               rdfs:label "audit evidence"@en .


###  https://w3id.org/pionera/daimo#CrossParticipantProvenanceRecord
:CrossParticipantProvenanceRecord rdf:type owl:Class ;
                                  rdfs:subClassOf <http://www.w3.org/ns/prov#Bundle> ;
                                  rdfs:comment "A reusable semantic bundle that aggregates prov:Activity and prov:Entity across participant contexts to tell one audit-ready story."@en ;
                                  rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                                  rdfs:label "cross-participant provenance record"@en .


###  https://w3id.org/pionera/daimo#DerivedArtifact
:DerivedArtifact rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/dcat#Resource> ,
                                 <http://www.w3.org/ns/prov#Entity> ;
                 rdfs:comment "A governed, catalog-describable output produced by an it6:Run in a dataspace context, bearing its own provenance and policy."@en ;
                 rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                 rdfs:label "derived artifact"@en .


###  https://w3id.org/pionera/daimo#Evaluator
:Evaluator rdf:type owl:Class ;
           rdfs:subClassOf :ParticipantRole ;
           rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
           rdfs:label "evaluator"@en .


###  https://w3id.org/pionera/daimo#ExecutionAuthorization
:ExecutionAuthorization rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.w3.org/ns/odrl/2/Agreement> ;
                        rdfs:comment "An ODRL agreement (produced by a DSP contract negotiation) that binds at least one odrl:permission to concrete it6:Run invocations it authorises. Specialises odrl:Agreement; MUST carry at least one odrl:permission per the ODRL policy model."@en ;
                        rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                        rdfs:label "execution authorization"@en .


###  https://w3id.org/pionera/daimo#GovernanceActor
:GovernanceActor rdf:type owl:Class ;
                 rdfs:subClassOf :ParticipantRole ;
                 rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                 rdfs:label "governance actor"@en .


###  https://w3id.org/pionera/daimo#IOContract
:IOContract rdf:type owl:Class ;
            rdfs:comment "The minimum machine-actionable invocation contract for a deployment: input format, output format, authentication method, and optional input/output schemas."@en ;
            rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
            rdfs:label "I/O contract"@en .


###  https://w3id.org/pionera/daimo#ModelConsumer
:ModelConsumer rdf:type owl:Class ;
               rdfs:subClassOf :ParticipantRole ;
               rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
               rdfs:label "model consumer"@en .


###  https://w3id.org/pionera/daimo#ModelDeployment
:ModelDeployment rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
                 rdfs:comment "A running or hosted instance of an MLDCAT-AP MachineLearningModel exposed through a dcat:DataService under an operational environment."@en ;
                 rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                 rdfs:label "model deployment"@en .


###  https://w3id.org/pionera/daimo#ModelProvider
:ModelProvider rdf:type owl:Class ;
               rdfs:subClassOf :ParticipantRole ;
               rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
               rdfs:label "model provider"@en .


###  https://w3id.org/pionera/daimo#ParticipantRole
:ParticipantRole rdf:type owl:Class ;
                 rdfs:comment "A dataspace-scoped role taken by a participant with respect to AI assets. Anti-rigid: an agent can gain and lose roles over time. Subclasses are intentionally NOT mutually disjoint — one agent can hold several roles simultaneously (e.g., a research group may be both Evaluator and Model Provider)."@en ;
                 rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                 rdfs:label "participant role"@en .


###  https://w3id.org/pionera/daimo#PlatformOperator
:PlatformOperator rdf:type owl:Class ;
                  rdfs:subClassOf :ParticipantRole ;
                  rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                  rdfs:label "platform operator"@en .


###  https://w3id.org/pionera/daimo#SharedEvaluationContext
:SharedEvaluationContext rdf:type owl:Class ;
                         rdfs:comment "A reified grouping of the conditions under which model results are comparable: task, dataset, dataset version, protocol, and random seed. Does not claim to cover every facet that affects comparability (metric, split strategy, hyperparameters); it is the minimum grouping required by CQ-V1..CQ-V3."@en ;
                         rdfs:isDefinedBy <https://w3id.org/pionera/daimo> ;
                         rdfs:label "shared evaluation context"@en .


