@prefix : <https://w3id.org/pionera/daimo#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/pionera/daimo#> .

<https://w3id.org/pionera/daimo> rdf:type owl:Ontology ;
                                  owl:versionIRI <https://w3id.org/pionera/daimo/0.1.6> ;
                                  <http://purl.org/dc/terms/conformsTo> <https://www.w3.org/TR/owl2-overview/> ;
                                  <http://purl.org/dc/terms/contributor> <https://ror.org/03n6nwv02> ;
                                  <http://purl.org/dc/terms/creator> _:genid1 ,
                                                                     _:genid2 ;
                                  <http://purl.org/dc/terms/description> "DAIMO is an integration profile that connects DCAT-AP, MLDCAT-AP, ODRL, PROV-O, and the Dataspace Protocol (DSP, as operationalised by Eclipse EDC) to support publication, discovery, invocation, execution traceability, and contextualised evaluation of AI model assets exchanged in dataspaces. The edc: namespace is used only for EDC-specific extensions (e.g., ParticipantContext) not yet standardised in DSP."@en ;
                                  <http://purl.org/dc/terms/issued> "2026-04-22"^^xsd:date ;
                                  <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                  <http://purl.org/dc/terms/modified> "2026-07-06"^^xsd:date ;
                                  <http://purl.org/dc/terms/publisher> <https://w3id.org/pionera> ;
                                  <http://purl.org/dc/terms/title> "DAIMO: an ontology for governed AI model assets in dataspaces"@en ;
                                  <http://purl.org/vocab/vann/preferredNamespacePrefix> "daimo" ;
                                  <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/pionera/daimo#" ;
                                  rdfs:comment "See the companion documents ONTOLOGY-REFERENCE.md (class-by-class reference), VALIDATION-MATRIX.md (traceability), and daimo-ontology-design.md (design rationale) in the source repository."@en ;
                                  rdfs:seeAlso <https://w3id.org/pionera/daimo/align> ,
                                               <https://w3id.org/pionera/daimo/docs> ,
                                               <https://w3id.org/pionera/daimo/shapes> ;
                                  owl:priorVersion <https://w3id.org/pionera/daimo/0.1.5> ;
                                  owl:versionInfo "0.1.6" .

_:genid1 rdf:type <http://xmlns.com/foaf/0.1/Person> ;
          rdfs:seeAlso <https://github.com/EdmundoMori> ;
          <http://xmlns.com/foaf/0.1/name> "Edmundo de Elvira Mori Orrillo"@en .

_:genid2 rdf:type <http://xmlns.com/foaf/0.1/Person> ;
          <http://xmlns.com/foaf/0.1/name> "Jiayun Liu"@en .

