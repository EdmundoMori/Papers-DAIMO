      {
        "@id": "http://www.w3.org/ns/odrl/2/"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "assignee"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/ns/odrl/2/Party"
      }
    ]
  },
  {
    "@id": "http://www.w3.org/ns/dcat#CatalogRecord",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "DCAT: a record in a data catalog describing the registration of a single dataset or data service."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://www.w3.org/ns/dcat"
      }
    ],
